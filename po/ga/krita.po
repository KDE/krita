msgid "Font Size"
msgstr "Méid Cló"

#: plugins/dockers/textproperties/qml/FontSize.qml:19
#, kde-format
msgctxt "@info:tooltip"
msgid "Font size allows setting the size of the characters."
msgstr "Ligeann méid an chló méid na gcarachtar a shocrú."

#: plugins/dockers/textproperties/qml/FontSize.qml:21
#, kde-format
msgctxt ""
"comma separated search terms for the fontsize property, matching is case-"
"insensitive"
msgid "size, small, big, medium"
msgstr "méid, beag, mór, meánach"

#: plugins/dockers/textproperties/qml/FontSizeAdjust.qml:13
#, kde-format
msgctxt "@label:spinbox"
msgid "Font Size Adjust"
msgstr "Coigeartaigh Méid an Chló"

#: plugins/dockers/textproperties/qml/FontSizeAdjust.qml:17
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Font size adjust allows setting a ratio that the x-height must be matched by."
msgstr ""
"Leis an gcoigeartú ar mhéid an chló, is féidir cóimheas a shocrú a "
"chaithfidh an airde-x a mheaitseáil."

#: plugins/dockers/textproperties/qml/FontSizeAdjust.qml:19
#, kde-format
msgctxt ""
"comma separated search terms for the fontsize adjust property, matching is "
"case-insensitive"
msgid "size, small, big, medium, font-size-adjust"
msgstr "méid, beag, mór, meánach, coigeartaigh méid an chló"

#: plugins/dockers/textproperties/qml/FontSizeAdjust.qml:84
#, kde-format
msgctxt "@label:button"
msgid "Calculate"
msgstr "Ríomh"

#: plugins/dockers/textproperties/qml/FontSizeAdjust.qml:85
#, kde-format
msgctxt "@info:tooltip"
msgid "Calculate the x-height to font size ratio for the first font family."
msgstr ""
"Ríomh an cóimheas idir airde-x agus méid an chló don chéad teaghlach clónna."

#: plugins/dockers/textproperties/qml/FontStyle.qml:13
#, kde-format
msgctxt "@label"
msgid "Font Style"
msgstr "Stíl Cló"

#: plugins/dockers/textproperties/qml/FontStyle.qml:18
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Font style allows setting the sub style of the given font family, such as "
"italics and bold"
msgstr ""
"Ligeann stíl chló fo-stíl an teaghlaigh chló ar leith a shocrú, amhail cló "
"iodálach agus cló trom"

#: plugins/dockers/textproperties/qml/FontStyle.qml:20
#, kde-format
msgctxt ""
"comma separated search terms for the fontsize property, matching is case-"
"insensitive"
msgid ""
"weight, width, style, italics, oblique, font-style, font-stretch, font-"
"weight, bold, optical-size, variation"
msgstr ""
"meáchan, leithead, stíl, cló iodálach, claonta, stíl chló, síneadh cló, "
"meáchan cló, trom, méid optúil, athrú"

