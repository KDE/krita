msgstr "Alternatív függőleges fél metrika"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:448
#, kde-format
msgctxt "@tooltip"
msgid ""
"Repositions glyphs so they are half-width in a vertical writing context."
msgstr ""
"Úgy pozicionálja át a karaktereket, hogy fél szélességűek legyenek "
"függőleges írásnál."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:451
#, kde-format
msgctxt "@title"
msgid "Vowel Jamo Forms"
msgstr "Magánhangzó jamo alakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:452
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of vowel class Hangul Jamo with a combined vowel form."
msgstr ""
"A magánhangzó osztályú hangul jamók sorozatát kombinált magánhangzó alakra "
"cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:455
#, kde-format
msgctxt "@title"
msgid "Vertical Kana Alternates"
msgstr "Függőleges kana alternatívák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:456
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces standard kana in Japanese fonts with ones suited for vertical "
"layout."
msgstr ""
"A japán betűkészletekben a szabványos kanákat függőleges elrendezéshez "
"alkalmasakra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:459
#, kde-format
msgctxt "@title"
msgid "Proportional Alternate Vertical Metrics"
msgstr "Proporcionális alternatív függőleges metrika"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:460
#, kde-format
msgctxt "@tooltip"
msgid ""
"Repositions glyphs so they are proportional in a vertical writing context."
msgstr ""
"Úgy pozicionálja át a karaktereket, hogy proporcionálisak legyenek "
"függőleges írásnál."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:463
#, kde-format
msgctxt "@title"
msgid "Vertical Alternates for Rotation"
msgstr "Függőleges alternatívák forgatáshoz"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:464
#, kde-format
msgctxt "@tooltip"
msgid "Replaces a subset of glyphs with rotated variants for vertical layout."
msgstr ""
"A karaktereket egy részét elforgatott változatokra cserél a függőleges "
"elrendezéshez."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:467
#, kde-format
msgctxt "@title"
msgid "Vertical Alternates and Rotation"
msgstr "Függőleges alternatívák és forgatás"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:468
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces all horizontal-script glyphs with rotated variants for vertical "
"layout."
msgstr ""
"Minden vízszintes írású karaktert elforgatott változatra cserél a függőleges "
"elrendezéshez."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:473
#, kde-format
msgctxt "@title"
msgid "Cursive Positioning"
msgstr "Kurzív pozicionálás"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:474
#, kde-format
msgctxt "@tooltip"
msgid "Adjusts the position of glyphs so they cursively connect."
msgstr "Úgy módosítja a karakterek helyzetét, hogy kurzívan kapcsolódjanak."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:477
#, kde-format
msgctxt "@title"
msgid "Terminal Forms"
msgstr "Záróalakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:478
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the final glyph in a sequence of glyphs in a joined script with its "
"end form."
msgstr "Egy összekapcsolt jelsorozat utolsó tagját a záróalakjára cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:481
#, kde-format
msgctxt "@title"
msgid "Terminal Form #2"
msgstr "2. záróalak"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:482
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the Alaph glyph at the end of Syriac words with its appropriate "
"form."
msgstr "A szír szavak végén lévő Alaph jelet a megfelelő alakjára cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:485
#, kde-format
msgctxt "@title"
msgid "Terminal Form #3"
msgstr "3. záróalak"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:486
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the Alaph glyph at the end of Syriac words with its appropriate "
"form, when neither Terminal forms or Terminal forms 2 are applicable."
msgstr ""
"A szír szavak végén lévő Alaph jelet a megfelelő alakjára cseréli, ha sem az "
"1., sem a 2. záróalak nem alkalmazható."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:489
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:493
#, kde-format
msgctxt "@title"
msgid "Initial Forms"
msgstr "Kezdőalakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:490
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the first glyph in a sequence of glyphs in a joined script with its "
"start form."
msgstr "Egy összekapcsolt jelsorozat első tagját a kezdőalakjára cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:494
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces a glyph in a sequence of glyphs in a joined script with its "
"isolated form."
msgstr "Egy összekapcsolt karakter sorozat tagját az izolált alakjára cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:497
#, kde-format
msgctxt "@title"
msgid "Left-to-right glyph alternates"
msgstr "Balról jobbra írású karakter-változatok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:498
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their left-to-right alternates."
msgstr "A karaktereket a balról jobbra íráshoz tartozó változataikra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:501
#, kde-format
msgctxt "@title"
msgid "Left-to-right mirrored forms"
msgstr "Balról jobbra tükrözött alakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:502
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their left-to-right mirrored forms."
msgstr "A karaktereket a balról jobbra tükrözött alakjukra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:505
#, kde-format
msgctxt "@title"
msgid "Medial Forms"
msgstr "Köztes alakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:506
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs in the middle of a sequence of glyphs in a joined script "
"with their medial forms."
msgstr ""
"Egy összekapcsolt karakter sorozat közepén lévő jeleket a köztes alakjukra "
"cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:509
#, kde-format
msgctxt "@title"
msgid "Medial Forms #2"
msgstr "2. köztes alak"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:510
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the Alaph glyph in the middle of Syriac words with its appropriate "
"form."
msgstr ""
"A szír szavak közepén lévő Alaph karaktert a megfelelő alakjára cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:513
#, kde-format
msgctxt "@title"
msgid "mset"
