#, kde-format
msgctxt "@title"
msgid "Medial Forms #2"
msgstr "Foirmeacha Leighis #2"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:510
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the Alaph glyph in the middle of Syriac words with its appropriate "
"form."
msgstr "Cuireann sé an fhoirm chuí in ionad an ghlif Alaph i lár focal Siriac."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:513
#, kde-format
msgctxt "@title"
msgid "mset"
msgstr "mset"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:514
#, kde-format
msgctxt "@tooltip"
msgid ""
"Positions Arabic combining marks in fonts for Windows 95 using glyph "
