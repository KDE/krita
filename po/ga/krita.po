"fhormáid seo."

#: libs/impex/CheckImageSize.h:27 libs/impex/ImageSizeCheck.h:26
#, kde-format
msgctxt "image conversion warning"
msgid ""
"This image is larger than <b>%1 x %2</b>. Images this size cannot be saved "
