#: libs/ui/forms/wdgapplyprofile.ui:107
#, kde-format
msgid ""
"Within and outside gamut; same as Absolute Colorimetric. White point changed "
"to result in neutral grays."
msgstr ""
"Laistigh agus lasmuigh den gamut; mar an gcéanna le Dathmhéadrach "
"Absalóideach. Athraíodh an pointe bán chun liath neodrach a thabhairt."

#. i18n: ectx: property (text), widget (QRadioButton, radioRelativeColorimetric)
#: libs/ui/forms/wdgapplyprofile.ui:110
#: libs/ui/forms/wdgconvertcolorspace.ui:76
