msgstr "Kiegészítő magánhasználatú terület-A"

#: libs/flake/text/data/KoUnicodeBlockData.cpp:358
#, kde-format
msgctxt "@title"
msgid "Supplementary Private Use Area-B"
msgstr "Kiegészítő magánhasználatú terület-B"

#: libs/flake/text/data/KoUnicodeBlockData.h:47
#, kde-format
msgctxt "@title"
msgid "No Block"
msgstr "Nincs blokk"

#: libs/flake/text/KoFontGlyphModel.cpp:408
#, kde-format
msgctxt "@info:tooltip"
msgid "%1 glyph variants."
msgstr "%1 karakter változat."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:24
#, kde-format
msgctxt "@title"
msgid "Access All Alternates"
msgstr "Az összes alternatíva elérése"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:25
#, kde-format
msgctxt "@tooltip"
msgid "Access any possible substitutions."
msgstr "Hozzáférés minden lehetséges helyettesítéshez."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:29
#, kde-format
msgctxt "@title"
msgid "Contextual Alternates"
msgstr "Kontextusfüggő alternatívák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:30
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs depending on their context within a text."
msgstr "Kicseréli a karaktereket a szövegkörnyezetük alapján."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:33
#, kde-format
msgctxt "@title"
msgid "Contextual Ligatures"
msgstr "Kontextusfüggő ligatúrák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:34
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of glyphs with ligatures depending on their context "
"within a text."
msgstr ""
"A karakter sorozatokat ligatúrákra cseréli a szövegkörnyezetük alapján."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:37
#, kde-format
msgctxt "@title"
msgid "Contextual Swash"
msgstr "Kontextusfüggő díszítés"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:38
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs with swashed glyphs depending on their context within a text."
msgstr ""
"Kicseréli a karaktereket díszített változatokra a szövegkörnyezetük alapján."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:41
#, kde-format
msgctxt "@title"
msgid "Discretionary Ligatures"
msgstr "Tetszőleges ligatúrák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:42
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of glyphs with ligatures intended for typographic effect."
msgstr "A karakter sorozatokat tipográfiai hatású ligatúrákra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:45
#, kde-format
msgctxt "@title"
msgid "Final Glyph on Line Alternates"
msgstr "Sorvégi karakterváltozatok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:46
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their line-end forms."
msgstr "Kicseréli a karaktereket a sorvégi alakjukra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:49
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:53
#, kde-format
msgctxt "@title"
msgid "Historical Forms"
msgstr "Történelmi alakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:50
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their historical forms."
msgstr "Kicseréli a karaktereket a történelmi alakjukra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:54
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences glyphs with ligatures that were in use in the past, but "
"rare today."
msgstr ""
"A jelsorozatokat olyan ligatúrákra cseréli, amelyek régen használatosak "
"voltak, de ma már ritkák."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:57
#, kde-format
msgctxt "@title"
msgid "Justification Alternates"
msgstr "Sorkizárási alternatívák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:58
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their alternates meant for justification."
msgstr "Kicseréli a karaktereket a sorkizáráshoz szánt változataikra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:61
#, kde-format
msgctxt "@title"
msgid "Standard Ligatures"
msgstr "Szabványos ligatúrák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:62
#, kde-format
msgctxt "@tooltip"
msgid "Replaces sequences glyphs with common ligatures."
msgstr "A jelsorozatokat gyakori ligatúrákra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:65
#, kde-format
msgctxt "@title"
msgid "Left Bounds"
msgstr "Bal oldali határok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:66
#, kde-format
msgctxt "@tooltip"
msgid "This adjusts glyphs so there is no space at the left side."
msgstr "Úgy igazítja a karaktereket, hogy ne legyen szóköz a bal oldalukon."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:69
#, kde-format
msgctxt "@title"
msgid "Localized Forms"
msgstr "Honosított alakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:70
#, kde-format
msgctxt "@tooltip"
msgid "This replaces glyphs with language specific versions."
msgstr "Kicseréli a karaktereket nyelvspecifikus változatokra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:73
#, kde-format
msgctxt "@title"
msgid "Optical Bounds"
msgstr "Optikai határok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:74
#, kde-format
msgctxt "@tooltip"
msgid ""
"Adjusts glyphs so they align by their optical bounds. Doesn't do anything in "
"Krita."
msgstr ""
"Úgy igazítja a karaktereket, hogy az optikai határuk mentén igazodjanak. A "
"Kritában nincs hatása."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:77
#, kde-format
msgctxt "@title"
msgid "Ornaments"
msgstr "Díszítőelemek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:78
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ornaments for decorative purposes."
msgstr "Kicseréli a karaktereket díszítőelemekre."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:81
#, kde-format
msgctxt "@title"
msgid "Randomize"
msgstr "Véletlenszerű"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:82
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with random alternates."
msgstr "Kicseréli a karaktereket véletlenszerű változatokra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:85
#, kde-format
msgctxt "@title"
msgid "Right Bounds"
msgstr "Jobb oldali határok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:86
#, kde-format
msgctxt "@tooltip"
msgid "This adjusts glyphs so there is no space at the right side."
msgstr "Úgy igazítja a karaktereket, hogy ne legyen szóköz a jobb oldalukon."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:89
#, kde-format
msgctxt "@title"
msgid "Stylistic Alternates"
msgstr "Stilisztikai alternatívák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:90
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs with stylistic alternates that do not fit in other "
"categories."
msgstr ""
"Kicseréli a karaktereket olyan stilisztikai változatokra, amelyek nem "
"illenek más kategóriákba."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:93
#, kde-format
msgctxt "@title"
msgid "Swash"
msgstr "Díszített"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:94
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with swashed alternates."
msgstr "Kicseréli a jeleket díszített változatokra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:99
#, kde-format
msgctxt "@title"
msgid "Glyph Composition/Decomposition"
msgstr "Jelösszetétel és szétbontás"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:100
#, kde-format
msgctxt "@tooltip"
msgid ""
"This composes or decomposes graphemes so that the resulting glyphs can later "
"be recomposed. Commonly used to handle diacritics."
msgstr ""
"Összeállítja vagy szétbontja a grafémákat, hogy a kapott jelek később újra "
"összeállíthatók legyenek. Gyakran használják mellékjelek kezelésére."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:103
#, kde-format
msgctxt "@title"
msgid "Kerning"
msgstr "Kerning"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:104
#, kde-format
msgctxt "@tooltip"
msgid "This controls kerning on the font."
msgstr "A betűkészlet alávágását szabályozza."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:107
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:111
#, kde-format
msgctxt "@title"
msgid "Mark Positioning"
msgstr "Jelölés pozicionálása"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:108
#, kde-format
msgctxt "@tooltip"
msgid ""
"This controls the positioning of mark glyphs on base glyphs. Commonly used "
"for diacritics."
msgstr ""
"A jelölő karakterek alapkarakterekhez viszonyított helyzetét szabályozza. "
"Gyakran használják mellékjelekhez."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:112
#, kde-format
msgctxt "@tooltip"
msgid ""
"This controls the positioning of mark glyphs onto other mark glyphs. "
"Commonly used for diacritics."
msgstr ""
"A jelölő karakterek más jelölő karakterekhez viszonyított helyzetét "
"szabályozza. Gyakran használják mellékjelekhez."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:115
#, kde-format
msgctxt "@title"
msgid "Required Contextual Alternates"
msgstr "Kötelező kontextusfüggő alternatívák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:116
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs contextually with alternates, required to make the font work."
msgstr ""
"Kontextusfüggő módon cseréli a karaktereket alternatívákra, ami szükséges a "
"betűkészlet működéséhez."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:119
#, kde-format
msgctxt "@title"
msgid "Required Ligatures"
msgstr "Kötelező ligatúrák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:120
#, kde-format
msgctxt "@tooltip"
msgid "Replaces sequences of glyphs with required ligatures."
msgstr "A karakter sorozatokat kötelező ligatúrákra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:123
#, kde-format
msgctxt "@title"
msgid "Required Variation Alternates"
msgstr "Kötelező variációs alternatívák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:124
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs in a variable font with ones suited for the current "
"variation."
msgstr ""
"Kicseréli a karaktereket egy változó betűkészletben az aktuális variációnak "
"megfelelőkre."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:127
#, kde-format
msgctxt "@title"
msgid "Optical size"
msgstr "Optikai méret"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:128
#, kde-format
msgctxt "@tooltip"
msgid ""
"Indicates how much the font is suitable for its current size. Does nothing "
"in Krita."
msgstr ""
"Jelzi, hogy a betűkészlet mennyire felel meg az aktuális méretének. A "
"Kritában nincs hatása."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:131
#, kde-format
msgctxt "@title"
msgid "Vertical Kerning"
msgstr "Függőleges kerning"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:132
#, kde-format
msgctxt "@tooltip"
msgid "This controls vertical kerning on the font."
msgstr "A betűkészlet függőleges alávágását szabályozza."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:137
#, kde-format
msgctxt "@title"
msgid "Alternative Fractions"
msgstr "Alternatív törtek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:138
#, kde-format
msgctxt "@tooltip"
msgid "Replaces figures separated by a slash with a nut fraction form."
msgstr ""
"A perjellel elválasztott számokat vízszintes törtvonalas alakra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:141
#, kde-format
msgctxt "@title"
msgid "Denominators"
msgstr "Nevezők"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:142
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces figures with forms that are suited to represent the denominator in "
"a fraction."
msgstr "A számokat a tört nevezőjének megfelelő alakúra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:145
#, kde-format
msgctxt "@title"
msgid "Dotless Forms"
msgstr "Pont nélküli alakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:146
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces dotted letters such as i and j with dotless forms, for use in "
"mathematical formula."
msgstr ""
"A pontozott betűket (például i és j) pont nélküli alakra cseréli matematikai "
"képletekben való használathoz."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:149
#, kde-format
msgctxt "@title"
msgid "Flattened accent forms"
msgstr "Lapos ékezetalakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:150
#, kde-format
msgctxt "@tooltip"
msgid "Replaces accents on capital letters with flattened forms."
msgstr "A nagybetűk ékezeteit laposabb alakúra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:153
#, kde-format
msgctxt "@title"
msgid "Fractions"
msgstr "Törtek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:154
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces figures separated by a slash with a proper diagonal fraction form. "
"If a font has the numerator and denominator features, and the numbers are "
"separated by a 'fraction slash' (U+2044), then this will replace the figures "
"with numerators before the slash and denominators after the slash."
msgstr ""
"A perjellel elválasztott számokat valódi átlós törtalakra cseréli. Ha a "
"betűkészlet rendelkezik számláló és nevező funkcióval, és a számokat "
"'törtperjel' (U+2044) választja el, akkor a perjel előtti számokat "
"számlálóvá, a perjel utániakat pedig nevezővé alakítja."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:157
#, kde-format
msgctxt "@title"
msgid "Lining Figures"
msgstr "Kurrens számjegyek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:158
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces oldstyle figures with lining figures, which harmonize well with "
"uppercase letters."
msgstr ""
"A régi stílusú számjegyeket kurrens alakokra cseréli,  melyek jól illenek a "
"nagybetűkhöz."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:161
#, kde-format
msgctxt "@title"
msgid "Mathematical Greek"
msgstr "Matematikai görög"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:162
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces normal Greek script with glyphs intended for mathematical usage."
msgstr ""
"A normál görög betűket matematikai használatra szánt karakterekre cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:165
#, kde-format
msgctxt "@title"
msgid "Alternate Annotation Forms"
msgstr "Alternatív jelölési formák"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:166
#, kde-format
msgctxt "@tooltip"
msgid "Replaces figures and letters with notational forms, like encircled."
msgstr ""
"A számokat és betűket jelölési formákra (például bekeretezettre) cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:169
#, kde-format
msgctxt "@title"
msgid "Numerators"
msgstr "Számlálók"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:170
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces figures with forms that are suited to represent the numerator in a "
"fraction."
msgstr ""
"A számokat a tört számlálójának ábrázolásához megfelelő alakúra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:173
#, kde-format
msgctxt "@title"
msgid "Oldstyle Figures"
msgstr "Régi stílusú számjegyek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:174
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces lining figures with oldstyle figures, which harmonize well with "
"lowercase letters."
msgstr ""
"A kurrens számjegyeket régi stílusú alakokra cseréli, melyek jól illenek a "
"kisbetűkhöz."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:177
#, kde-format
msgctxt "@title"
msgid "Ordinals"
msgstr "Sorszámnevek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:178
#, kde-format
msgctxt "@tooltip"
msgid "Replaces letters that follow figures with their ordinal forms."
msgstr "A számokat követő betűket sorszámnévi alakúra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:181
#, kde-format
msgctxt "@title"
msgid "Proportional Figures"
msgstr "Arányos szélességű számjegyek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:182
#, kde-format
msgctxt "@tooltip"
msgid "Replaces tabular figures with proportional figures."
msgstr "Az azonos szélességű számjegyeket arányos szélességű alakokra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:185
#, kde-format
msgctxt "@title"
msgid "Scientific Inferiors"
msgstr "Tudományos alsó index"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:186
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs with forms that are suited for displaying the number in "
"chemical formulas."
msgstr ""
"A karaktereket a kémiai képletek megjelenítésére alkalmas alakúra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:189
#, kde-format
msgctxt "@title"
msgid "Math script style alternates"
msgstr "Matematikai írásstílus-változatok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:190
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ones more suited for super- and subscripts."
msgstr "A karaktereket az alsó és felső indexekhez jobban illőkre cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:193
#, kde-format
msgctxt "@title"
msgid "Subscript"
msgstr "Alsó index"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:194
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ones more suited for subscript."
msgstr "A karaktereket az alsó indexhez jobban illőkre cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:197
#, kde-format
msgctxt "@title"
msgid "Superscript"
msgstr "Felső index"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:198
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ones more suited for superscript."
msgstr "A karaktereket a felső indexhez jobban illőkre cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:201
#, kde-format
msgctxt "@title"
msgid "Tabular Figures"
msgstr "Azonos szélességű számjegyek"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:202
#, kde-format
msgctxt "@tooltip"
msgid "Replaces proportional figures with tabular figures."
msgstr "Az arányos szélességű számjegyeket azonos szélességű alakokra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:205
#, kde-format
msgctxt "@title"
msgid "Slashed Zero"
msgstr "Áthúzott nulla"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:206
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the number zero with one that has a slash in the middle, which can "
"help prevent confusion with similar glyphs like the letter 'O'."
msgstr ""
"A nulla számjegyet áthúzott nullára cseréli, ami segít elkerülni az "
"összetévesztést a hasonló karakterekkel, például az 'O' betűvel."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:211
#, kde-format
msgctxt "@title"
msgid "Case-Sensitive Forms"
msgstr "Kis- és nagybetűérzékeny alakok"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:212
#, kde-format
msgctxt "@tooltip"
msgid ""
"Adjusts glyphs to work better with text that consists of only capitals or "
"lining figures."
msgstr ""
"Úgy módosítja a jeleket, hogy jobban illeszkedjenek a csupa nagybetűből vagy "
"kurrens számjegyekből álló szövegekhez."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:215
#, kde-format
msgctxt "@title"
msgid "Capital Spacing"
msgstr "Nagybetűs térköz"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:216
#, kde-format
msgctxt "@tooltip"
msgid "Adjusts inter-glyph spacing for all-capital text."
msgstr "Módosítja a jelek közötti távolságot csupa nagybetűs szöveg esetén."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:219
#, kde-format
msgctxt "@title"
msgid "Petite Capitals From Capitals"
msgstr "Nagybetűkből kiskapitális"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:220
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces uppercase letters with petite capital forms, which are closer to "
"the x-height of a font than small capital forms."
msgstr ""
"A nagybetűket kiskapitális (petite) alakúra cseréli, amelyek közelebb állnak "
"a betűkészlet x-magasságához, mint a normál kiskapitális (small caps) alakok."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:223
#, kde-format
msgctxt "@title"
msgid "Small Capitals From Capitals"
msgstr "Nagybetűkből kiskapitális"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:224
#, kde-format
msgctxt "@tooltip"
msgid "Replaces uppercase letters with small capital forms."
msgstr "A nagybetűket kiskapitális alakúra cseréli."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:227
#, kde-format
msgctxt "@title"
msgid "Petite Capitals"
msgstr "Kiskapitális (petite)"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:228
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces lowercase letters with petite capital forms, which are closer to "
"the x-height of a font than small capital forms."
msgstr ""
"A kisbetűket kiskapitális (petite) alakúra cseréli, amelyek közelebb állnak "
