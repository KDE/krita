#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:493
#, kde-format
msgctxt "@title"
msgid "Initial Forms"
msgstr "Foirmeacha Tosaigh"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:490
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the first glyph in a sequence of glyphs in a joined script with its "
"start form."
msgstr ""
"Cuireann sé seo a fhoirm tosaigh in ionad an chéad ghlif i seicheamh glifí i "
"script ceangailte."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:494
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces a glyph in a sequence of glyphs in a joined script with its "
"isolated form."
msgstr ""
"Cuireann sé seo glif i seicheamh glif i script ceangailte in ionad a fhoirm "
"scoite."

