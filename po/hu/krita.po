msgid "Save as:"
msgstr "Mentés másként:"

#. i18n: ectx: property (text), widget (QRadioButton, flattenLayers)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:46
#, kde-format
msgid "Flattened image"
msgstr "Lapított kép"

#. i18n: ectx: property (text), widget (QRadioButton, haveAnimation)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:56
#: plugins/paintops/libpaintop/KisPredefinedBrushModel.cpp:60
#, kde-format
msgid "Animated image"
msgstr "Animált kép"

#. i18n: ectx: property (text), widget (QRadioButton, multiLayer)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:63
#, kde-format
msgid "Multi-layered image"
msgstr "Többrétegű kép"

#. i18n: ectx: property (text), widget (QRadioButton, multiPage)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:70
#, kde-format
msgid "Multi-paged image"
msgstr "Többoldalas kép"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox)
#. i18n: ectx: property (title), widget (QGroupBox, groupBox_2)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:80
#: plugins/impex/webp/kis_wdg_options_webp.ui:44
#, kde-format
msgid "Encoding options"
msgstr "Kódolási beállítások"

#. i18n: ectx: property (toolTip), widget (QGroupBox, lossyEncoding)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:89
#, kde-format
msgid "If this is not enabled, the image will be saved losslessly."
msgstr "Ha nincs engedélyezve, a kép veszteségmentesen lesz elmentve."

#. i18n: ectx: property (title), widget (QGroupBox, lossyEncoding)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:92
#, kde-format
msgid "Lossy encoding"
msgstr "Veszteséges kódolás"

#. i18n: ectx: property (text), widget (QLabel, lblHighQual)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:110
#: plugins/paintops/libpaintop/KisDynamicSensorFactoryRegistry.cpp:24
#: plugins/paintops/libpaintop/KisDynamicSensorFactoryRegistry.cpp:27
#, kde-format
msgid "High"
msgstr "Magas"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, lossyQuality)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:124
#, kde-format
msgid ""
"Set the lossy quality of JPEG-XL export.\n"
"Default: 90 (visually lossless)."
msgstr ""
"A JPEG-XL exportálás veszteséges minőségének beállítása.\n"
"Alapértelmezett: 90 (vizuálisan veszteségmentes)."

#. i18n: ectx: property (text), widget (QLabel, lblLowQual)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:140
#: plugins/paintops/libpaintop/KisDynamicSensorFactoryRegistry.cpp:24
#: plugins/paintops/libpaintop/KisDynamicSensorFactoryRegistry.cpp:27
#, kde-format
msgid "Low"
msgstr "Alacsony"

#. i18n: ectx: property (toolTip), widget (QCheckBox, forceModular)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:151
#, kde-format
msgid ""
"Use modular encoding instead of default VarDCT for lossy compression\n"
"(e.g. for non-photographic images).\n"
"Default: disabled."
msgstr ""
"Moduláris kódolás használata az alapértelmezett VarDCT helyett a veszteséges "
"tömörítéshez\n"
"(pl. nem fénykép típusú képek esetén).\n"
"Alapértelmezett: kikapcsolva."

#. i18n: ectx: property (text), widget (QCheckBox, forceModular)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:154
#, kde-format
msgid "Use modular mode"
msgstr "Moduláris mód használata"

#. i18n: ectx: property (toolTip), widget (QCheckBox, losslessAlpha)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:161
#, kde-format
msgid ""
"<html><head/><body><p>If enabled, this will set alpha channel (transparency) "
"to lossless. Useful to reduce transparency artifact on lossy export.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Ha engedélyezve van, az alfa-csatorna (átlátszóság) "
"veszteségmentes lesz. Hasznos az átlátszósági hibák csökkentésére "
"veszteséges exportálásnál.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, losslessAlpha)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:164
#, kde-format
msgid "Lossless alpha"
msgstr "Veszteségmentes alfa"

#. i18n: ectx: property (text), widget (QLabel, lblTradeoff)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:174
#: plugins/impex/webp/kis_wdg_options_webp.ui:95
#, kde-format
msgid "Tradeoff"
msgstr "Kompromisszum"

#. i18n: ectx: property (text), widget (QLabel, lblFaster)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:183
#: plugins/impex/webp/kis_wdg_options_webp.ui:104
#, kde-format
msgid "Faster"
msgstr "Gyorsabb"

#. i18n: ectx: property (text), widget (QLabel, lblSlowerBetter)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:190
#: plugins/impex/webp/kis_wdg_options_webp.ui:111
#, kde-format
msgid "Slower/Better"
msgstr "Lassabb/Jobb"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, effort)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:202
#, kde-format
msgid ""
"Sets encoder effort/speed level without affecting decoding speed.\n"
"Valid values are, from faster to slower speed: 1:lightning 2:thunder 3:"
"falcon 4:cheetah 5:hare 6:wombat 7:squirrel 8:kitten 9:tortoise.\n"
"Default: squirrel (7)."
msgstr ""
"Beállítja a kódoló erőfeszítési/sebességi szintjét a dekódolási sebesség "
"befolyásolása nélkül.\n"
"Érvényes értékek a gyorsabbtól a lassabb felé: 1:lightning (villám) 2:"
"thunder (mennydörgés) 3:falcon (sólyom) 4:cheetah (gepárd) 5:hare (nyúl) 6:"
"wombat 7:squirrel (mókus) 8:kitten (kiscica) 9:tortoise (teknős).\n"
"Alapértelmezett: squirrel (7)."

#. i18n: ectx: property (text), widget (QLabel, label_2)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:220
#, kde-format
msgid "Decoding speed"
msgstr "Dekódolási sebesség"

#. i18n: ectx: property (text), widget (QLabel, lblSlowest)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:229
#, kde-format
msgid "Slowest/Best quality"
msgstr "Leglassabb/Legjobb minőség"

#. i18n: ectx: property (text), widget (QLabel, lblSlowerBetter2)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:236
#, kde-format
msgid "Fastest/Slight quality loss"
msgstr "Leggyorsabb/Enyhe minőségromlás"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, decodingSpeed)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:248
#, kde-format
msgid ""
"Sets the decoding speed tier for the provided options.\n"
"Minimum is 0 (slowest to decode, best quality/density), and maximum is 4 "
"(fastest to decode, at the cost of some quality/density).\n"
"Default is 0."
msgstr ""
"Beállítja a dekódolási sebesség szintjét a megadott opciókhoz.\n"
"A minimum a 0 (leglassabb dekódolás, legjobb minőség/sűrűség), a maximum "
"pedig a 4 (leggyorsabb dekódolás, némi minőség/sűrűség árán).\n"
"Alapértelmezett a 0."

#. i18n: ectx: property (title), widget (QGroupBox, colorProfileGrp)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:286
#, kde-format
msgid "Color profile"
msgstr "Színprofil"

#. i18n: ectx: property (toolTip), widget (QCheckBox, forceCicpLossless)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:292
#, kde-format
msgid ""
"<html><head/><body><p>Use CICP if ICC profile is convertible to CICP on "
"lossless, otherwise keep using ICC. Useful to make filesize even smaller "
"(eg. for web delivery).</p></body></html>"
msgstr ""
"<html><head/><body><p>CICP használata, ha az ICC profil konvertálható CICP-"
"re veszteségmentesen, különben továbbra is ICC használata. Hasznos a "
"fájlméret további csökkentéséhez (pl. webes közzétételhez).</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, forceCicpLossless)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:295
#, kde-format
msgid "(Lossless) Use CICP instead of ICC if possible"
msgstr "(Veszteségmentes) CICP használata ICC helyett, ha lehetséges"

#. i18n: ectx: property (title), widget (QGroupBox, hdrConversionGrp)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:305
#, kde-format
msgid "HDR conversion"
msgstr "HDR konverzió"

#. i18n: ectx: property (text), widget (QLabel, explanationLabel)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:311
#, kde-format
msgid ""
"Applications like Google Chrome expect HDR images to store their color "
"profile as CICP values. You can adjust the ICC profile conversion below."
msgstr ""
"Az olyan alkalmazások, mint a Google Chrome, elvárják, hogy a HDR képek CICP "
"értékként tárolják a színprofiljukat. Alább módosíthatja az ICC profil "
"konverzióját."

#. i18n: ectx: property (text), widget (QLabel, label_5)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:412
#, kde-format
msgid "Hover this text for info tooltip"
msgstr "Húzza ide az egeret a súgó megjelenítéséhez"

#. i18n: ectx: property (whatsThis), widget (QFrame, liquifyOptionsLayout)
#. i18n: ectx: property (toolTip), widget (QTabWidget, advancedParameters)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:419
#: plugins/tools/tool_transform2/wdg_tool_transform.ui:1809
#, kde-format
msgid "<html><head/><body><p><br/></p></body></html>"
msgstr "<html><head/><body><p><br/></p></body></html>"

#. i18n: ectx: attribute (title), widget (QWidget, encoderParameters)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:426
#, kde-format
msgid "Encoder parameters"
msgstr "Kódoló paraméterei"

#. i18n: ectx: property (toolTip), widget (QLabel, lblResampling)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:432
#, kde-format
msgid ""
"<html><head/><body><p>Reduces color resolution to achieve smaller files. "
"Only recommended for low quality settings as it reduces sharpness at color "
"transitions.</p></body></html>"
msgstr ""
"<html><head/><body><p>Csökkenti a színfelbontást a kisebb fájlméret "
"érdekében. Csak alacsony minőségi beállításokhoz ajánlott, mivel csökkenti "
"az élességet a színátmeneteknél.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblResampling)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:435
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Color channel resampling"
msgstr "Színcsatorna-almintavételezés"

#. i18n: ectx: property (toolTip), widget (QComboBox, resampling)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:442
#, kde-format
msgid ""
"Sets resampling option. If enabled, the image's color channels are "
"downsampled before compression, and upsampled to original size in the "
"decoder."
msgstr ""
"Beállítja az újramintavételezési opciót. Ha engedélyezve van, a kép "
"színcsatornái lefelé lesznek mintavételezve a tömörítés előtt, a dekódolóban "
"pedig visszaállnak az eredeti méretre."

#. i18n: ectx: property (toolTip), widget (QLabel, lblAlphaResampling)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:449
#, kde-format
msgid ""
"<html><head/><body><p>Reduces transparency channel resolution for smaller "
"files. Only recommended for low quality or when precise transparency edges "
"aren't critical.</p></body></html>"
msgstr ""
"<html><head/><body><p>Csökkenti az átlátszósági csatorna felbontását a "
"kisebb fájlméret érdekében. Csak alacsony minőséghez ajánlott, vagy ha a "
"pontos átlátszósági szélek nem kritikusak.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblAlphaResampling)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:452
#, kde-format
msgid "Alpha channel resampling"
msgstr "Alfa-csatorna újramintavételezése"

#. i18n: ectx: property (toolTip), widget (QComboBox, extraChannelResampling)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:459
#, kde-format
msgid ""
"Sets resampling option. If enabled, the image's alpha channel is downsampled "
"before compression, and upsampled to original size in the decoder."
msgstr ""
"Beállítja az újramintavételezési opciót. Ha engedélyezve van, a kép alfa-"
"csatornája lefelé lesz mintavételezve a tömörítés előtt, a dekódolóban pedig "
"visszaáll az eredeti méretre."

#. i18n: ectx: property (toolTip), widget (QLabel, lblPhotonNoise)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:466
#, kde-format
msgid ""
"<html><head/><body><p>Separates camera sensor noise patterns for better "
"compression. Higher values reconstruct more noise, useful for preserving the "
"natural look of high-ISO photos.</p></body></html>"
msgstr ""
"<html><head/><body><p>Elkülöníti a kameraérzékelő zajmintáit a jobb "
"tömörítés érdekében. Magasabb értékek több zajt rekonstruálnak, ami hasznos "
"a magas ISO-értékű fotók természetes megjelenésének megőrzéséhez.</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblPhotonNoise)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:469
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Photon noise"
msgstr "Foton-zaj"

#. i18n: ectx: property (toolTip), widget (QSpinBox, photonNoise)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:484
#, kde-format
msgid ""
"Adds noise to the image emulating photographic film noise, the higher the "
"given number, the grainier the image will be.\n"
"As an example, a value of 100 gives low noise whereas a value of 3200 gives "
"a lot of noise.\n"
"The default value is 0."
msgstr ""
"Zajt ad a képhez, a fotófilm zaját utánozva. Minél nagyobb a megadott szám, "
"annál szemcsésebb lesz a kép.\n"
"Például a 100-as érték alacsony zajt, míg a 3200-as érték sok zajt "
"eredményez.\n"
"Az alapértelmezett érték 0."

#. i18n: ectx: property (toolTip), widget (QLabel, lblDots)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:494
#, kde-format
msgid ""
"<html><head/><body><p>Identifies and efficiently encodes repeating dot "
"patterns in the image. Useful for scanned documents and certain textures.</"
"p></body></html>"
msgstr ""
"<html><head/><body><p>Azonosítja és hatékonyan kódolja az ismétlődő "
"pontmintákat a képen. Hasznos szkennelt dokumentumoknál és bizonyos "
"textúráknál.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblDots)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:497
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Generate dots"
msgstr "Pontok generálása"

#. i18n: ectx: property (toolTip), widget (QComboBox, dots)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:504
#, kde-format
msgid "Enables or disables dots generation."
msgstr "Engedélyezi vagy kikapcsolja a pontok generálását."

#. i18n: ectx: property (toolTip), widget (QLabel, label)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:511
#, kde-format
msgid ""
"<html><head/><body><p>Identifies repeated elements (like text characters or "
"icons) and stores them once, referencing them elsewhere. Improves "
"compression for digital illustrations and screenshots.</p></body></html>"
msgstr ""
"<html><head/><body><p>Azonosítja az ismétlődő elemeket (például szöveges "
"karaktereket vagy ikonokat), és csak egyszer tárolja el őket, máshol pedig "
"hivatkozik rájuk. Javítja a digitális illusztrációk és képernyőképek "
"tömörítését.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:514
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Generate patches"
msgstr "Foltok generálása"

#. i18n: ectx: property (toolTip), widget (QComboBox, patches)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:521
#, kde-format
msgid "Enables or disables patches generation."
msgstr "Engedélyezi vagy kikapcsolja a foltok generálását."

#. i18n: ectx: property (toolTip), widget (QLabel, lblEpf)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:528
#, kde-format
msgid ""
"<html><head/><body><p>Smooths areas while preserving sharp edges, improving "
"compression without blurring important details. Higher values apply stronger "
"filtering.</p></body></html>"
msgstr ""
"<html><head/><body><p>Simítja a területeket az éles szélek megőrzése "
"mellett, javítva a tömörítést a fontos részletek elmosása nélkül. Magasabb "
"értékek erősebb szűrést alkalmaznak.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblEpf)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:531
#, kde-format
msgid "Edge preserving filter strength"
msgstr "Élmegőrző szűrő erőssége"

#. i18n: ectx: property (text), widget (QLabel, lblMax)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:555
#: plugins/paintops/colorsmudge/kis_colorsmudgeop_settings_widget.cpp:110
#: plugins/paintops/defaultpaintops/duplicate/kis_duplicateop_settings_widget.cpp:46
#, kde-format
msgid "Strong"
msgstr "Erős"

#. i18n: ectx: property (toolTip), widget (QLabel, lblNone1)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:565
#, kde-format
msgid "<html><head/><body><p>Default (encoder chooses)</p></body></html>"
msgstr ""
"<html><head/><body><p>Alapértelmezett (a kódoló választ)</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblNone1)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:568
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Auto"
msgstr "Auto"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, epf)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:575
#, kde-format
msgid ""
"Edge preserving filter level, -1 to 3. Use -1 for the default (encoder "
"chooses), 0 to 3 to set a strength."
msgstr ""
"Élmegőrző szűrő szintje, -1-től 3-ig. Használja a -1-et az "
"alapértelmezetthez (a kódoló választ), a 0-3 értéket pedig az erősség "
"beállításához."

#. i18n: ectx: property (toolTip), widget (QComboBox, gaborish)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:596
#, kde-format
msgid "Enables or disables the gaborish filter."
msgstr "Engedélyezi vagy kikapcsolja a gaborish szűrőt."

#. i18n: ectx: property (toolTip), widget (QLabel, lblGaborishFilter)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:603
#, kde-format
msgid ""
"<html><head/><body><p>Advanced texture analysis filter that improves "
"compression of complex textured areas while preserving visual quality.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Fejlett textúraelemző szűrő, amely javítja az "
"összetett textúrájú területek tömörítését a vizuális minőség megőrzése "
"mellett.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblGaborishFilter)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:606
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Gaborish filter"
msgstr "Gaborish szűrő"

#. i18n: ectx: property (toolTip), widget (QLabel, lbModularEncoding)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:613
#, kde-format
msgid ""
"<html><head/><body><p>Uses the Modular compression system which excels at "
"compressing graphics with sharp edges and limited colors. Can be lossless or "
"lossy.</p></body></html>"
msgstr ""
"<html><head/><body><p>A moduláris tömörítési rendszert használja, amely "
"kiváló az éles szélekkel és kevés színnel rendelkező grafikák tömörítésére. "
"Lehet veszteségmentes vagy veszteséges.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lbModularEncoding)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:616
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Modular encoding"
msgstr "Moduláris kódolás"

#. i18n: ectx: property (toolTip), widget (QComboBox, modular)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:623
#, kde-format
msgid "Enables modular encoding."
msgstr "Engedélyezi a moduláris kódolást."

#. i18n: ectx: property (toolTip), widget (QComboBox, keepInvisible)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:630
#, kde-format
msgid "Enables or disables preserving color of invisible pixels."
msgstr ""
"Engedélyezi vagy kikapcsolja a láthatatlan pixelek színének megőrzését."

#. i18n: ectx: property (toolTip), widget (QComboBox, groupOrder)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:637
#, kde-format
msgid ""
"Determines the order in which 256x256 regions are stored in the codestream "
"for progressive rendering."
msgstr ""
"Meghatározza a 256x256-os régiók kódfolyamban való tárolásának sorrendjét a "
"progresszív megjelenítéshez."

#. i18n: ectx: property (toolTip), widget (QLabel, lblKeepInvisible)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:647
#, kde-format
msgid ""
"<html><head/><body><p>Preserves color information in fully transparent "
"areas. Disable to reduce file size when colors under transparency aren't "
"needed.</p></body></html>"
msgstr ""
"<html><head/><body><p>Megőrzi a színinformációkat a teljesen átlátszó "
"területeken. Kapcsolja ki a fájlméret csökkentéséhez, ha az átlátszóság "
"alatti színekre nincs szükség.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblKeepInvisible)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:650
#, kde-format
msgid "Keep color of invisible pixels"
msgstr "Láthatatlan pixelek színének megőrzése"

#. i18n: ectx: property (toolTip), widget (QLabel, lblGroupOrder)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:657
#, kde-format
msgid ""
"<html><head/><body><p>Determines the order in which image tiles are encoded. "
"'Center first' prioritizes the center of the image for progressive loading, "
"useful for web content.</p></body></html>"
msgstr ""
"<html><head/><body><p>Meghatározza a képcsempék kódolásának sorrendjét. A "
"'Középről kifelé' a kép közepét részesíti előnyben a progresszív "
"betöltésnél, ami hasznos webes tartalmaknál.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblGroupOrder)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:660
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Group order"
msgstr "Csoportsorrend"

#. i18n: ectx: property (toolTip), widget (QLabel, lblJPEGReconCFL)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:670
#, kde-format
msgid ""
"<html><head/><body><p>Predicts color from brightness information, reducing "
"file size. Very effective for natural images where brightness and color are "
"correlated.</p></body></html>"
msgstr ""
"<html><head/><body><p>A színt a fényerő-információkból jósolja meg, "
"csökkentve a fájlméretet. Nagyon hatékony természetes képeknél, ahol a "
"fényerő és a szín összefügg.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblJPEGReconCFL)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:673
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Chroma-from-luma"
msgstr "Chroma-a-lumából"

#. i18n: ectx: attribute (title), widget (QWidget, varDCTParameters)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:681
#, kde-format
msgid "VarDCT parameters"
msgstr "VarDCT paraméterek"

#. i18n: ectx: property (toolTip), widget (QLabel, lblProgressiveAC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:687
#, kde-format
msgid ""
"<html><head/><body><p>Enables progressive loading using advanced color "
"mathematics for fine details. Images load as a rough preview that becomes "
"progressively sharper. Takes more time but provides better results.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Lehetővé teszi a progresszív betöltést fejlett "
"színmatematika használatával a finom részletekhez. A képek durva "
"előnézetként töltődnek be, amely fokozatosan élesedik. Több időt vesz "
"igénybe, de jobb eredményt ad.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblProgressiveAC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:690
#, kde-format
msgid "Spectral progression"
msgstr "Spektrális progresszió"

#. i18n: ectx: property (toolTip), widget (QComboBox, progressiveAC)
#. i18n: ectx: property (toolTip), widget (QComboBox, qProgressiveAC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:697
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:714
#, kde-format
msgid ""
"Set the progressive mode for the AC coefficients of VarDCT, using spectral "
"progression from the DCT coefficients."
msgstr ""
"A VarDCT AC-együtthatóinak progresszív módjának beállítása a DCT-"
"együtthatókból származó spektrális progresszióval."

#. i18n: ectx: property (toolTip), widget (QLabel, lblQProgressiveAC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:704
#, kde-format
msgid ""
"<html><head/><body><p>Enables progressive loading using quantization to "
"compress fine details. Results in smaller file sizes but requires more "
"encoding time.</p></body></html>"
msgstr ""
"<html><head/><body><p>Lehetővé teszi a progresszív betöltést kvantálás "
"használatával a finom részletek tömörítéséhez. Kisebb fájlméretet "
"eredményez, de több kódolási időt igényel.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblQProgressiveAC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:707
#, kde-format
msgid "Quantization"
msgstr "Kvantálás"

#. i18n: ectx: property (toolTip), widget (QLabel, lblProgressiveDC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:721
#, kde-format
msgid ""
"<html><head/><body><p>Creates a better coarse preview image for progressive "
"loading. Adds a few bytes to file size but improves the initial low-"
"resolution preview quality.</p></body></html>"
msgstr ""
"<html><head/><body><p>Jobb durva előnézeti képet hoz létre a progresszív "
"betöltéshez. Pár bájttal növeli a fájlméretet, de javítja a kezdeti kis "
"felbontású előnézet minőségét.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblProgressiveDC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:724
#, kde-format
msgid "Low resolution DC"
msgstr "Kis felbontású DC"

#. i18n: ectx: property (toolTip), widget (QComboBox, progressiveDC)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:731
#, kde-format
msgid "Set the progressive mode using lower-resolution DC images for VarDCT."
msgstr ""
"Progresszív mód beállítása alacsonyabb felbontású DC-képek használatával a "
"VarDCT-hez."

#. i18n: ectx: attribute (title), widget (QWidget, modularEncodingParameters)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:739
#, kde-format
msgid "Modular parameters"
msgstr "Moduláris paraméterek"

#. i18n: ectx: property (toolTip), widget (QLabel, lblResponsive)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:745
#, kde-format
msgid ""
"<html><head/><body><p>Enables the 'Squeeze' transform that allows images to "
"load progressively from low to high quality as data streams in.</p></body></"
"html>"
msgstr ""
"<html><head/><body><p>Engedélyezi a 'Squeeze' transzformációt, amely "
"lehetővé teszi a képek progresszív betöltését alacsonytól a jó minőségig az "
"adatok beérkezésekor.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblResponsive)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:748
#, kde-format
msgid "Progressive encoding"
msgstr "Progresszív kódolás"

#. i18n: ectx: property (toolTip), widget (QComboBox, responsive)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:755
#, kde-format
msgid "Enables or disables progressive encoding for modular mode."
msgstr "Engedélyezi vagy kikapcsolja a progresszív kódolást moduláris módban."

#. i18n: ectx: property (toolTip), widget (QLabel, lblChannelColorsGlobalPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:762
#, kde-format
msgid ""
"<html><head/><body><p>Controls how color values are mapped across the entire "
"image. 'All' uses the full range; smaller percentages create more efficient "
"compression for images with limited color ranges.</p></body></html>"
msgstr ""
"<html><head/><body><p>Szabályozza, hogyan képeződnek le a színértékek a "
"teljes képen. Az 'Összes' a teljes tartományt használja; a kisebb százalékok "
"hatékonyabb tömörítést tesznek lehetővé korlátozott színtartományú képeknél."
"</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblChannelColorsGlobalPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:765
#, kde-format
msgid "Global channel palette range"
msgstr "Globális csatorna-palettatartomány"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, channelColorsGlobalPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:776
#, kde-format
msgid ""
"Use Global channel palette if the amount of colors is smaller than this "
"percentage of range.\n"
"Use 0-100 to set an explicit percentage, -1 to use the encoder default.\n"
"Used for modular encoding."
msgstr ""
"Globális csatorna-paletta használata, ha a színek mennyisége kisebb, mint a "
"tartomány ezen százaléka.\n"
"Használjon 0-100 közötti értéket a konkrét százalékhoz, vagy -1-et a kódoló "
"alapértelmezéséhez.\n"
"Moduláris kódoláshoz használatos."

#. i18n: ectx: property (toolTip), widget (QLabel, lblChannelColorsGroupPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:817
#, kde-format
msgid ""
"<html><head/><body><p>Controls color mapping within local 256×256 pixel "
"tiles. More efficient for images with areas of limited color variety.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Szabályozza a színleképezést a helyi 256×256 pixeles "
"csempéken belül. Hatékonyabb olyan képeknél, amelyek korlátozott "
"színváltozatosságú területeket tartalmaznak.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblChannelColorsGroupPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:820
#, kde-format
msgid "Local channel palette range"
msgstr "Helyi csatorna-palettatartomány"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, channelColorsGroupPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:831
#, kde-format
msgid ""
"Use Local (per-group) channel palette if the amount of colors is smaller "
"than this percentage of range.\n"
"Use 0-100 to set an explicit percentage, -1 to use the encoder default.\n"
"Used for modular encoding."
msgstr ""
"Helyi (csoportonkénti) csatorna-paletta használata, ha a színek mennyisége "
"kisebb, mint a tartomány ezen százaléka.\n"
"Használjon 0-100 közötti értéket a konkrét százalékhoz, vagy -1-et a kódoló "
"alapértelmezéséhez.\n"
"Moduláris kódoláshoz használatos."

#. i18n: ectx: property (toolTip), widget (QLabel, lblPaletteColors)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:872
#, kde-format
msgid ""
"<html><head/><body><p>Activates palette-based compression when the image "
"contains this number of unique colors or fewer. -1 lets the encoder decide "
"automatically.</p></body></html>"
msgstr ""
"<html><head/><body><p>Aktiválja a palettaalapú tömörítést, ha a kép ennyi "
"vagy kevesebb egyedi színt tartalmaz. A -1 hagyja, hogy a kódoló döntsön "
"automatikusan.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblPaletteColors)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:875
#, kde-format
msgid "Use color palette for ... colors or less"
msgstr "Színpaletta használata ... színnél vagy kevesebbnél"

#. i18n: ectx: property (toolTip), widget (QSpinBox, paletteColors)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:889
#, kde-format
msgid ""
"Use color palette if amount of colors is smaller than or equal to this "
"amount, or -1 to use the encoder default.\n"
"Used for modular encoding."
msgstr ""
"Színpaletta használata, ha a színek száma kisebb vagy egyenlő ezzel az "
"értékkel, vagy -1 a kódoló alapértelmezéséhez.\n"
"Moduláris kódoláshoz használatos."

#. i18n: ectx: property (toolTip), widget (QLabel, lblLossyPalette)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:911
#, kde-format
msgid ""
"<html><head/><body><p>Enables relative color encoding that stores "
"differences between predicted and actual colors. Excellent for near-lossless "
"compression of smooth gradients without banding artifacts.</p></body></html>"
msgstr ""
"<html><head/><body><p>Engedélyezi a relatív színkódolást, amely a jósolt és "
"a tényleges színek közötti különbséget tárolja. Kiváló a sima átmenetek "
"közel veszteségmentes tömörítéséhez sávosodási hibák nélkül.</p></body></"
"html>"

#. i18n: ectx: property (text), widget (QLabel, lblLossyPalette)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:914
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Delta palette"
msgstr "Delta paletta"

#. i18n: ectx: property (toolTip), widget (QComboBox, lossyPalette)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:921
#, kde-format
msgid "Enables or disables delta palette. Used in modular mode."
msgstr ""
"Engedélyezi vagy kikapcsolja a delta palettát. Moduláris módban használatos."

#. i18n: ectx: property (toolTip), widget (QLabel, lblModularGroupSize)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:928
#, kde-format
msgid ""
"<html><head/><body><p>Sets the tile size for compression. Larger groups may "
"improve compression but require more memory.</p></body></html>"
msgstr ""
"<html><head/><body><p>Beállítja a tömörítés csempeméretét. A nagyobb "
"csoportok javíthatják a tömörítést, de több memóriát igényelnek.</p></body></"
"html>"

#. i18n: ectx: property (text), widget (QLabel, lblModularGroupSize)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:931
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Group size"
msgstr "Csoportméret"

#. i18n: ectx: property (toolTip), widget (QComboBox, modularGroupSize)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:938
#, kde-format
msgid "Group size for modular encoding."
msgstr "Csoportméret a moduláris kódoláshoz."

#. i18n: ectx: property (toolTip), widget (QComboBox, modularPredictor)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:945
#, kde-format
msgid "Predictor for modular encoding."
msgstr "Vonal-előrejelző a moduláris kódoláshoz."

#. i18n: ectx: property (toolTip), widget (QLabel, lblModularPredictor)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:952
#, kde-format
msgid ""
"<html><head/><body><p>Selects the algorithm used to predict pixel values "
"based on surrounding pixels. Different predictors work better for different "
"image types.</p></body></html>"
msgstr ""
"<html><head/><body><p>Kiválasztja a pixelértékek környező pixelek alapján "
"történő megjóslására használt algoritmust. A különböző vonal-előrejelzők "
"különböző képtípusoknál működnek jobban.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblModularPredictor)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:955
#, kde-format
msgctxt "JPEG-XL encoder options"
msgid "Predictor"
msgstr "Vonal-előrejelző"

#. i18n: ectx: property (toolTip), widget (QLabel, lblModularMATreeLearningPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:962
#, kde-format
msgid ""
"<html><head/><body><p>Controls how many pixels are analyzed to build the "
"meta-adaptive decision tree that selects the optimal predictor for each "
"pixel. Higher values may improve compression but take longer.</p></body></"
"html>"
msgstr ""
"<html><head/><body><p>Szabályozza, hogy hány pixelt elemezzen a meta-adaptív "
"döntési fa felépítéséhez, amely kiválasztja az optimális vonal-előrejelzőt "
"minden pixelhez. A magasabb értékek javíthatják a tömörítést, de tovább "
"tartanak.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, lblModularMATreeLearningPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:965
#, kde-format
msgid "Pixels for MA tree learning"
msgstr "Pixelek az MA-fa tanításához"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, modularMATreeLearningPercent)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:993
#, kde-format
msgid ""
"Fraction of pixels used to learn MA trees as a percentage.\n"
"-1 = default, 0 = no MA and fast decode, 50 = default value, 100 = all.\n"
"Higher values use more encoder memory."
msgstr ""
"Az MA-fák tanításához használt pixelek aránya százalékban.\n"
"-1 = alapértelmezett, 0 = nincs MA és gyors dekódolás, 50 = alapértelmezett "
"érték, 100 = összes.\n"
"A magasabb értékek több kódolómemóriát használnak."

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_4)
#: plugins/impex/jxl/kis_wdg_options_jpegxl.ui:1066
#, kde-format
msgctxt "JPEG-XL metadata options"
msgid "Filters:"
msgstr "Szűrők:"

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:138
#, kde-format
msgid "Could not load embedded reference image %1 "
msgstr "A(z) %1 beágyazott referenciakép betöltése sikertelen "

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:143
#, kde-format
msgctxt "@info"
msgid ""
"A reference image linked to an external file could not be loaded.\n"
"\n"
"Path: %1\n"
"\n"
"Do you want to select another location?"
msgstr ""
"Külső fájlra hivatkozó referenciaképet nem sikerült betölteni.\n"
"\n"
"Elérési út: %1\n"
"\n"
"Szeretne másik helyet választani?"

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:148
#: plugins/impex/libkra/kis_kra_loader.cpp:697
#: plugins/impex/libkra/kis_kra_loader.cpp:1147
#, kde-format
msgctxt "@title:window"
msgid "File not found"
msgstr "Fájl nem található"

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:258
#, kde-format
msgctxt "Warning during loading a kra file with a filter layer"
msgid ""
"Selection on layer %s couldn't be loaded. It will be replaced by an empty "
"selection."
msgstr ""
"A(z) %s rétegen lévő kijelölést nem sikerült betölteni. Üres kijelöléssel "
"lesz helyettesítve."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:321
#, kde-format
msgctxt "Loading a .kra file"
msgid ""
"The file contains a clone layer that has an incorrect source node id. This "
"layer will be converted into a paint layer."
msgstr ""
"A fájl olyan klónréteget tartalmaz, amelynek helytelen a forráscsomópont-"
"azonosítója. Ez a réteg festőréteggé lesz alakítva."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:393
#, kde-format
msgid "Could not load \"id\" of the transform mask"
msgstr "A transzformációs maszk azonosítójának (id) betöltése sikertelen"

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:400
#, kde-format
msgid "Could not find transform mask XML element"
msgstr "Nem található a transzformációs maszk XML-eleme"

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:422
#, kde-format
msgid "Could not create transform mask params"
msgstr "A transzformációs maszk paramétereinek létrehozása sikertelen"

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:574
#, kde-format
msgid "Could not find keyframe pixel data for frame %1 in %2."
msgstr "Nem található kulcskocka pixeladat a(z) %1. képkockához itt: %2."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:582
#, kde-format
msgid "Could not load keyframe pixel data for frame %1 in %2."
msgstr ""
"A kulcskocka pixeladatainak betöltése sikertelen a(z) %1. képkockához itt: "
"%2."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:611
#, kde-format
msgid "Could not read pixel data: %1."
msgstr "A pixeladatok olvasása sikertelen: %1."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:618
#, kde-format
msgid "Could not load pixel data: %1."
msgstr "A pixeladatok betöltése sikertelen: %1."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:634
#, kde-format
msgid "Could not load profile: %1."
msgstr "A profil betöltése sikertelen: %1."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:689
#, kde-format
msgid "Could not filter configuration %1."
msgstr "A(z) %1 szűrőkonfiguráció betöltése sikertelen."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:730
#, kde-format
msgid "Could not load metadata for layer %1."
msgstr "A(z) %1. réteg metaadatainak betöltése sikertelen."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:773
#, kde-format
msgid "Could not load vector selection %1."
msgstr "A(z) %1 vektorkijelölés betöltése sikertelen."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:789
#, kde-format
msgid "Could not load raster selection %1."
msgstr "A(z) %1 raszterkijelölés betöltése sikertelen."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:819
#, kde-format
msgid "Could not load keyframes from %1."
msgstr "A kulcskockákat betöltése sikertelen innen: %1."

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:837
#: plugins/impex/libkra/kis_kra_load_visitor.cpp:840
#, kde-format
msgid ""
"parsing error in the keyframe file %1 at line %2, column %3\n"
"Error message: %4"
msgstr ""
"feldolgozási hiba a(z) %1 kulcskocka-fájlban a(z) %2. sor %3. oszlopában\n"
"Hibaüzenet: %4"

#: plugins/impex/libkra/kis_kra_load_visitor.cpp:854
#, kde-format
msgid "unknown keyframe channel type: %1 in %2"
msgstr "ismeretlen kulcskocka csatornatípus %1 itt: %2"

#: plugins/impex/libkra/kis_kra_loader.cpp:210
#, kde-format
msgid "Image does not have a name."
msgstr "A képnek nincs neve."

#: plugins/impex/libkra/kis_kra_loader.cpp:215
#, kde-format
