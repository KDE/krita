#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:518
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their right-to-left alternates."
msgstr "Cuireann sé glifí in ionad a roghanna malartacha ó dheis go clé."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:521
#, kde-format
msgctxt "@title"
msgid "Right-to-left mirrored forms"
msgstr "Foirmeacha scáthánaithe ó dheis go clé"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:522
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their right-to-left mirrored forms."
msgstr "Cuireann sé a bhfoirmeacha scáthánaithe ó dheis go clé in ionad glifí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:525
#, kde-format
msgctxt "@title"
msgid "Stretching Glyph Decomposition"
