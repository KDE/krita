#: plugins/dockers/textproperties/qml/LetterSpacing.qml:18
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Letter spacing controls the spacing between visible clusters of characters."
msgstr ""
"Rialaíonn spásáil litreacha an spásáil idir braislí infheicthe carachtar."

#: plugins/dockers/textproperties/qml/LetterSpacing.qml:20
#, kde-format
msgctxt ""
"comma separated search terms for the letter-spacing property, matching is "
"case-insensitive"
