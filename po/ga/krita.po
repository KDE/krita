msgid "Line Break"
msgstr "Briseadh Líne"

#: plugins/dockers/textproperties/qml/LineBreak.qml:17
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Line break allows choosing a strictness for the line breaking algorithm. "
"Mostly used for CJK scripts, requires language being set."
msgstr ""
"Ligeann briseadh líne déine a roghnú don algartam briseadh líne. Úsáidtear é "
"den chuid is mó le haghaidh scripteanna CJK, agus éilíonn sé go socrófar "
"teanga."

#: plugins/dockers/textproperties/qml/LineBreak.qml:19
#, kde-format
msgctxt ""
"comma separated search terms for the line-break property, matching is case-"
"insensitive"
msgid "line-break, line breaking, strictness, kinsoku"
msgstr "briseadh líne, briseadh líne, déine, kinsoku"

#: plugins/dockers/textproperties/qml/LineBreak.qml:78
#, kde-format
msgctxt "@info:tooltip"
msgid "No particular adjustments are made to the line break algorithm"
msgstr "Ní dhéantar aon choigeartuithe sonracha ar an algartam briseadh líne"

#: plugins/dockers/textproperties/qml/LineBreak.qml:79
#, kde-format
msgctxt "@label:inlistbox"
msgid "Loose"
msgstr "Scaoilte"

#: plugins/dockers/textproperties/qml/LineBreak.qml:80
#, kde-format
msgctxt "@info:tooltip"
msgid "While typically defines a looser algorithm, currently same as auto."
msgstr ""
"Cé go sainmhíníonn sé algartam níos scaoilte de ghnáth, tá sé mar an gcéanna "
"le auto faoi láthair."

#: plugins/dockers/textproperties/qml/LineBreak.qml:82
