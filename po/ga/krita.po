#, kde-format
msgctxt "@info:tooltip"
msgid ""
"The language of this text shape. Language affects a number of properties, "
"like glyph shape, upper- and lowercase and line breaking"
msgstr ""
"Teanga chruth an téacs seo. Bíonn tionchar ag an teanga ar roinnt airíonna, "
"amhail cruth an ghlif, litreacha móra agus beaga agus briseadh líne"

#: plugins/dockers/textproperties/qml/Language.qml:20
#, kde-format
msgctxt ""
