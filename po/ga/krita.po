#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs that need to stretch with stretchable glyphs."
msgstr ""
"Cuireann sé glifí inshínte in ionad glifí a gcaithfear síneadh a dhéanamh."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:536
#, kde-format
msgctxt "@title"
msgid "Stylistic Set %1"
