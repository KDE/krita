msgstr "Tá an liosta teaghlaigh folamh."

#: plugins/dockers/textproperties/qml/FontFamily.qml:171
#, kde-format
msgid "Add Fallback Family"
msgstr "Cuir Teaghlach Cúltaca leis"

#: plugins/dockers/textproperties/qml/FontKerning.qml:16
#, kde-format
msgctxt "@label"
msgid "Font Kerning"
msgstr "Cló-chorrú"

#: plugins/dockers/textproperties/qml/FontKerning.qml:20
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Turn font kerning on or off. Font kerning enables per-glyph spacing "
"adjustments as determined by the font."
msgstr ""
"Cas air nó as an gcearnadh cló. Cumasaíonn an chéarnadh cló coigeartuithe "
"spásála in aghaidh an ghlif de réir mar a chinneann an cló."

#: plugins/dockers/textproperties/qml/FontKerning.qml:22
#, kde-format
msgctxt ""
"comma separated search terms for the font-kerning property, matching is case-"
"insensitive"
msgid "font-kerning, tracking"
msgstr "rianú cló, rianú"

