#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:404
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with quarter-width glyphs."
msgstr "Cuireann sé glifí ceathrú leithead in ionad glifí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:407
#, kde-format
msgctxt "@title"
msgid "Ruby Notation Forms"
msgstr "Foirmeacha Nótaíochta Ruby"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:408
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs in CJK fonts with ones suited for the small text in ruby "
"annotations."
msgstr ""
"Cuireann sé glifí in ionad clónna CJK le cinn atá oiriúnach don téacs beag "
"in anótálacha ruby."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:411
#, kde-format
msgctxt "@title"
msgid "Simplified Forms"
msgstr "Foirmeacha Simplithe"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:412
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs in CJK fonts with 'simplified' forms."
msgstr "Cuireann sé foirmeacha 'simplithe' in ionad glifí i gclónna CJK."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:415
#, kde-format
msgctxt "@title"
msgid "Trailing Jamo Forms"
msgstr "Foirmeacha Jamo Leantacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:416
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of trailing class Hangul Jamo with a combined trailing "
"form."
msgstr ""
"Cuireann sé foirm chomhcheangailte ina háit, ina dhiaidh sin, seichimh den "
"rang deiridh Hangul Jamo."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:419
#, kde-format
msgctxt "@title"
msgid "Traditional Name Forms"
msgstr "Foirmeacha Ainmneacha Traidisiúnta"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:420
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces standard form Kanji in Japanese fonts with the ones traditionally "
"used in names."
msgstr ""
"Cuireann sé Kanji caighdeánach i gclónna Seapánacha in ionad na gclónna a "
"úsáidtear go traidisiúnta in ainmneacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:423
#, kde-format
msgctxt "@title"
msgid "Traditional Forms"
msgstr "Foirmeacha Traidisiúnta"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:424
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs in CJK fonts with 'traditional' forms."
msgstr "Cuireann sé foirmeacha 'traidisiúnta' in ionad glifí i gclónna CJK."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:427
#, kde-format
msgctxt "@title"
msgid "Third Widths"
msgstr "Tríú Leithead"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:428
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with third-width glyphs."
msgstr "Cuireann sé glifí den tríú leithead in ionad glifí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:431
#, kde-format
msgctxt "@title"
msgid "Alternate Vertical Metrics"
msgstr "Méadrachtaí Ingearacha Malartacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:432
#, kde-format
msgctxt "@tooltip"
msgid "Repositions glyphs so they look more appropriate in vertical layout."
msgstr ""
"Athshuíonn sé glifí ionas go mbeidh cuma níos oiriúnaí orthu i leagan amach "
"ingearach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:435
#, kde-format
msgctxt "@title"
msgid "Alternate Half Widths"
msgstr "Leathleithid Malartacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:436
#, kde-format
msgctxt "@tooltip"
msgid "Repositions glyphs so they look more appropriate in horizontal layout."
msgstr ""
"Athshuíonn sé glifí ionas go mbeidh cuma níos oiriúnaí orthu i leagan amach "
"cothrománach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:439
#, kde-format
msgctxt "@title"
msgid "Vertical Contextual Half-width Spacing"
msgstr "Spásáil Leathleithid Chomhthéacsúil Ingearach"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:443
#, kde-format
msgctxt "@title"
msgid "Vertical Alternates"
msgstr "Malartaigh Ingearacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:444
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs in CJK fonts with ones suited for vertical writing."
msgstr ""
"Cuireann sé glifí atá oiriúnach do scríbhneoireacht ingearach in ionad "
"clónna CJK."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:447
#, kde-format
msgctxt "@title"
msgid "Alternate Vertical Half Metrics"
msgstr "Leathmhéadracht Ingearach Malartach"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:448
#, kde-format
msgctxt "@tooltip"
msgid ""
"Repositions glyphs so they are half-width in a vertical writing context."
msgstr ""
"Athshuíonn sé glifí ionas go mbeidh siad leathleithead i gcomhthéacs "
"scríbhneoireachta ingearach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:451
#, kde-format
msgctxt "@title"
msgid "Vowel Jamo Forms"
msgstr "Foirmeacha Guta Jamo"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:452
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of vowel class Hangul Jamo with a combined vowel form."
msgstr ""
"Cuireann sé foirm chomhcheangailte guta in ionad seichimh den aicme guta "
"Hangul Jamo."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:455
#, kde-format
msgctxt "@title"
msgid "Vertical Kana Alternates"
msgstr "Malartaigh Kana Ingearach"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:456
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces standard kana in Japanese fonts with ones suited for vertical "
"layout."
msgstr ""
"Cuireann sé clónna atá oiriúnach do leagan amach ingearach in ionad kana "
"caighdeánach i gclónna Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:459
#, kde-format
msgctxt "@title"
msgid "Proportional Alternate Vertical Metrics"
msgstr "Méadrachtaí Ingearacha Malartacha Comhréireacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:460
#, kde-format
msgctxt "@tooltip"
msgid ""
"Repositions glyphs so they are proportional in a vertical writing context."
msgstr ""
"Athshuíonn sé glifí sa chaoi go mbeidh siad comhréireach i gcomhthéacs "
"scríbhneoireachta ingearach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:463
#, kde-format
msgctxt "@title"
msgid "Vertical Alternates for Rotation"
msgstr "Malartaigh Ingearacha le haghaidh Rothlaithe"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:464
#, kde-format
msgctxt "@tooltip"
msgid "Replaces a subset of glyphs with rotated variants for vertical layout."
msgstr ""
"Cuireann sé fo-thacar de ghlifí in ionad malairtí rothlaithe le haghaidh "
"leagan amach ingearach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:467
#, kde-format
msgctxt "@title"
msgid "Vertical Alternates and Rotation"
msgstr "Malartaigh Ingearacha agus Rothlú"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:468
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces all horizontal-script glyphs with rotated variants for vertical "
"layout."
msgstr ""
"Cuireann sé seo malairtí rothlaithe in ionad na nglif scripte cothrománacha "
"go léir le haghaidh leagan amach ingearach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:473
#, kde-format
msgctxt "@title"
msgid "Cursive Positioning"
msgstr "Suíomh Cursive"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:474
#, kde-format
msgctxt "@tooltip"
msgid "Adjusts the position of glyphs so they cursively connect."
msgstr ""
"Coigeartaíonn sé suíomh na nglif ionas go mbeidh siad ceangailte go réidh."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:477
#, kde-format
msgctxt "@title"
msgid "Terminal Forms"
msgstr "Foirmeacha Teirminéal"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:478
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the final glyph in a sequence of glyphs in a joined script with its "
"end form."
msgstr ""
"Cuireann sé seo an glifín deiridh i seicheamh glifí i script ceangailte in "
"ionad a fhoirm dheireanaí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:481
#, kde-format
msgctxt "@title"
msgid "Terminal Form #2"
msgstr "Foirm Teirminéal #2"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:482
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the Alaph glyph at the end of Syriac words with its appropriate "
"form."
msgstr ""
"Cuireann sé an fhoirm chuí in ionad an ghlif Alaph ag deireadh focal Siriac."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:485
#, kde-format
msgctxt "@title"
msgid "Terminal Form #3"
msgstr "Foirm Teirminéal #3"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:486
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the Alaph glyph at the end of Syriac words with its appropriate "
"form, when neither Terminal forms or Terminal forms 2 are applicable."
msgstr ""
"Cuireann sé an fhoirm chuí in ionad an ghlif Alaph ag deireadh focal Siriac, "
