#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:537
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:551
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with alternates."
