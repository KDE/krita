msgctxt "image conversion warning"
msgid ""
"This image is larger than <b>%1 x %2</b>. Images this size cannot be saved "
"to this format."
msgstr ""
"Ez a kép nagyobb, mint <b>%1 x %2</b>. Ilyen méretű képek nem menthetők ebbe "
"a formátumba."

#: libs/impex/ColorModelCheck.h:31
#, kde-format
msgctxt "image conversion warning"
msgid ""
"The color model <b>%1</b> or channel depth <b>%2</b> cannot be saved to this "
"format. Your image will be converted."
msgstr ""
"A(z) <b>%1</b> színmodell vagy a(z) <b>%2</b> csatornamélység nem menthető "
"ebbe a formátumba. A kép át lesz alakítva."

#: libs/impex/ColorModelHomogenousCheck.h:112
#, kde-format
msgctxt "image conversion warning"
msgid ""
"Your image contains layers with a color model that is different from the "
"image. The layers will be converted."
msgstr ""
"A kép a kép színmodelljétől eltérő rétegeket tartalmaz. A rétegek át lesznek "
"alakítva."

#: libs/impex/ColorModelPerLayerCheck.h:116
#, kde-format
msgctxt "image conversion warning"
msgid ""
"Your image contains layers with the color model <b>%1</b> and channel depth "
"<b>%2</b> which cannot be saved to this format. The layers will be converted."
msgstr ""
"A kép <b>%1</b> színmodellű és <b>%2</b> csatornamélységű rétegeket "
"tartalmaz, amelyek nem menthetők ebbe a formátumba. A rétegek át lesznek "
"alakítva."

#: libs/impex/CompositionsCheck.h:23
#, kde-format
msgctxt "image conversion warning"
msgid ""
"The image contains <b>compositions</b>. The compositions will not be saved."
msgstr ""
"A kép <b>kompozíciókat</b> tartalmaz. A kompozíciók nem lesznek elmentve."

#: libs/impex/ExifCheck.h:28
#, kde-format
msgctxt "image conversion warning"
msgid ""
"The image contains <b>Exif</b> metadata. The metadata will not be saved."
msgstr ""
"A kép <b>Exif</b> metaadatokat tartalmaz. A metaadatok nem lesznek elmentve."

#: libs/impex/ExifCheck.h:75
#, kde-format
msgctxt "image conversion warning"
msgid ""
"The image has <b>Exif</b> metadata and multiple layers. Only metadata <b>in "
"the first layer</b> will be saved."
msgstr ""
"A kép <b>Exif</b> metaadatokat és több réteget tartalmaz. Csak az <b>első "
"rétegben</b> található metaadatok lesznek elmentve."

#: libs/impex/FillLayerTypeCheck.h:92
#, kde-format
msgctxt "image conversion warning"
msgid ""
"The image contains a Fill Layer of type <b>%1</b>, which is not supported, "
"the layer will be converted to a paintlayer"
msgstr ""
"A kép <b>%1</b> típusú kitöltőréteget tartalmaz, ami nem támogatott; a réteg "
"festőréteggé lesz alakítva"

#: libs/impex/IntegralFrameDuration.h:32
#, kde-format
msgctxt "image conversion warning"
msgid ""
"The image is animated with a frame duration in <b>fractions of a "
"millisecond</b>. The format cannot represent this, and the frame duration "
"will be rounded to the nearest millisecond."
msgstr ""
"A kép animált, és a képkockák időtartama <b>tört ezredmásodpercben</b> van "
"megadva. A formátum ezt nem tudja kezelni, ezért az időtartam kerekítve lesz "
"a legközelebbi ezredmásodpercre."

