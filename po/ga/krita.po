#, kde-format
msgctxt "image conversion warning"
msgid ""
"The image contains <b>Exif</b> metadata. The metadata will not be saved."
msgstr ""
"Tá meiteashonraí <b>Exif</b> san íomhá. Ní shábhálfar na meiteashonraí."

#: libs/impex/ExifCheck.h:75
#, kde-format
msgctxt "image conversion warning"
