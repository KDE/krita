msgstr "%1 (típus: \"%2\")"

#: plugins/impex/exr/exr_converter.cc:1358
#, kde-format
msgctxt "@info"
msgid ""
"<p>The following layers have a type that is not supported by EXR format:</"
"p><r><ul>%1</ul></p><p><warning>these layers have <b>not</b> been saved to "
"the final EXR file</warning></p>"
msgstr ""
"<p>A következő rétegek típusa nem támogatott az EXR formátumban:</p><r><ul>"
"%1</ul></p><p><warning>ezek a rétegek <b>nem</b> lettek elmentve a végső EXR "
"fájlba</warning></p>"

