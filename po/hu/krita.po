#. i18n: ectx: property (text), widget (QLabel, label_7)
#: libs/ui/forms/wdgperformancesettings.ui:415
#, kde-format
msgid ""
"<html><head/><body><p>When performance logging is enabled Krita saves timing "
"information into the <tt>&lt;working_dir&gt;/log</tt> folder. If you "
"experience performance problems and want to help us, enable this option and "
"add the contents of the directory to a bug report.</p></body></html>"
msgstr ""
"<html><head/><body><p>Ha a teljesítménynaplózás engedélyezve van, a Krita az "
"időzítési információkat a <tt>&lt;working_dir&gt;/log</tt> mappába menti. Ha "
"teljesítményproblémákat tapasztal, és segíteni szeretne nekünk, engedélyezze "
"ezt az opciót, és csatolja a könyvtár tartalmát a hibajelentéshez.</p></"
"body></html>"

#. i18n: ectx: attribute (title), widget (QWidget, tab_3)
#: libs/ui/forms/wdgperformancesettings.ui:442
#, kde-format
msgid "Animation Cache"
msgstr "Animációs gyorsítótár"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_3)
#: libs/ui/forms/wdgperformancesettings.ui:448
#, kde-format
msgid "Cache Storage Backend"
msgstr "Gyorsítótár-tárolási alrendszer"

#. i18n: ectx: property (toolTip), widget (QRadioButton, optInMemory)
#: libs/ui/forms/wdgperformancesettings.ui:454
#, kde-format
msgid ""
"<html><head/><body><p>Animation frame cache will be stored in RAM completely "
"without any limitations</p><p><span style=\" font-weight:600;\">WARNING:</"
"span> please make sure your computer has enough RAM <span style=\" text-"
"decoration: underline;\">above</span> the amount you requested in General "
"tab. Otherwise you might face system freezes.</p><p>* for 1 second of "
"FullHD@25fps video you need extra 200 MiB of memory</p><p>* for 1 second of "
"4K UltraHD@25fps video you need extra 800 MiB of memory</p></body></html>"
msgstr ""
"<html><head/><body><p>Az animációs képkockák gyorsítótára korlátozás nélkül, "
"teljes egészében a RAM-ban lesz tárolva.</p><p><span style=\" font-"
"weight:600;\">FIGYELEM:</span> győződjön meg róla, hogy számítógépében "
"elegendő RAM áll rendelkezésre az Általános lapon kért mennyiségen <span "
"style=\" text-decoration: underline;\">felül</span> is. Ellenkező esetben a "
"rendszer lefagyhat.</p><p>* 1 másodpercnyi FullHD@25fps videóhoz további 200 "
"MiB memóriára van szükség</p><p>* 1 másodpercnyi 4K UltraHD@25fps videóhoz "
"további 800 MiB memóriára van szükség</p></body></html>"

#. i18n: ectx: property (text), widget (QRadioButton, optInMemory)
#: libs/ui/forms/wdgperformancesettings.ui:457
#, kde-format
msgid "In-memory"
msgstr "Memóriában"

#. i18n: ectx: property (toolTip), widget (QRadioButton, optOnDisk)
#: libs/ui/forms/wdgperformancesettings.ui:464
#, kde-format
msgid ""
"<html><head/><body><p>Animation frames are stored on hard disk in the same "
"folder as swap file. The cache is stored in a compressed way. Little amount "
"of extra RAM is needed.</p><p>Since data transfer speed of the hard drive is "
"low, you might want to limit cached frame size to be able to play your video "
"at 25 fps. The limit of 2500 px is usually a good choice.</p></body></html>"
msgstr ""
"<html><head/><body><p>Az animációs képkockák a merevlemezen, a lapozófájllal "
"azonos mappában tárolódnak. A gyorsítótár tömörítve van, így kevés extra RAM "
"szükséges.</p><p>Mivel a merevlemez adatátviteli sebessége alacsony, érdemes "
"korlátozni a gyorsítótárazott képkockaméretet a 25 fps sebességű "
"lejátszáshoz. A 2500 px-es korlát általában jó választás.</p></body></html>"

#. i18n: ectx: property (text), widget (QRadioButton, optOnDisk)
#: libs/ui/forms/wdgperformancesettings.ui:467
#, kde-format
msgid "On-disk"
msgstr "Lemezen"

#. i18n: ectx: property (title), widget (QGroupBox, groupBox_5)
#: libs/ui/forms/wdgperformancesettings.ui:477
#, kde-format
msgid "Cache Generation Options"
msgstr "Gyorsítótár-létrehozási beállítások"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkCachedFramesSizeLimit)
#: libs/ui/forms/wdgperformancesettings.ui:483
#, kde-format
msgid ""
"<html><head/><body><p>Render scaled down version of the frame if the image "
"is bigger than the provided limit. Make sure you enable this option when "
"using on-disk storage backend.</p></body></html>"
msgstr ""
"<html><head/><body><p>A képkocka lekicsinyített verziójának renderelése, ha "
"a kép nagyobb a megadott korlátnál. Győződjön meg róla, hogy engedélyezi ezt "
"az opciót lemezes tárolási alrendszer használatakor.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkCachedFramesSizeLimit)
#: libs/ui/forms/wdgperformancesettings.ui:486
#, kde-format
msgid "Limit cached frame size:"
msgstr "Gyorsítótárazott képkockaméret korlátozása:"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, intCachedFramesSizeLimit)
#: libs/ui/forms/wdgperformancesettings.ui:499
#, kde-format
msgid ""
"<html><head/><body><p>Size limit after which the frames will be scaled down</"
"p><p><span style=\" font-weight:600;\">Recommended value:</span> 2500&nbsp;"
"px</p></body></html>"
msgstr ""
"<html><head/><body><p>Méretkorlát, amely felett a képkockák lekicsinyítésre "
"kerülnek</p><p><span style=\" font-weight:600;\">Javasolt érték:</span> "
"2500&nbsp;px</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkUseRegionOfInterest)
#: libs/ui/forms/wdgperformancesettings.ui:506
#, kde-format
msgid ""
"<html><head/><body><p>When the image is too big, render only currently "
"visible part of it</p></body></html>"
msgstr ""
"<html><head/><body><p>Ha a kép túl nagy, csak a jelenleg látható részét "
"renderelje le</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkUseRegionOfInterest)
#: libs/ui/forms/wdgperformancesettings.ui:509
#, kde-format
msgid "Use region of interest"
msgstr "Érintett terület használata"

#. i18n: ectx: property (toolTip), widget (KisSliderSpinBox, intRegionOfInterestMargin)
#: libs/ui/forms/wdgperformancesettings.ui:522
#, no-c-format, kde-format
msgid ""
"<html><head/><body><p>Add extra area to the region of interest to each side "
"of the canvas.</p><p><span style=\" font-weight:600;\">Recommended value:</"
"span> 25%. The region of interest will be extended by 25% to each side.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Extra terület hozzáadása az érintett területhez a "
"vászon minden oldalán.</p><p><span style=\" font-weight:600;\">Javasolt "
"érték:</span> 25%. Az érintett terület minden oldalon 25%-kal lesz "
"megnövelve.</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QCheckBox, chkBackgroundCacheGeneration)
#: libs/ui/forms/wdgperformancesettings.ui:529
#, kde-format
msgid ""
"<html><head/><body><p>Automatically prerender animation cache in background "
"when the user is idle</p></body></html>"
msgstr ""
"<html><head/><body><p>Az animációs gyorsítótár automatikus előrenderelése a "
"háttérben, amikor a felhasználó inaktív</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, chkBackgroundCacheGeneration)
#: libs/ui/forms/wdgperformancesettings.ui:532
#, kde-format
msgid "Enable background cache generation"
msgstr "Háttérbeli gyorsítótár-létrehozás engedélyezése"

