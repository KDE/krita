msgstr "Gan Bloc"

#: libs/flake/text/KoFontGlyphModel.cpp:407
#, kde-format
msgctxt "@info:tooltip"
msgid "%1 glyph variants."
msgstr "%1 malairt glif."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:24
#, kde-format
msgctxt "@title"
msgid "Access All Alternates"
msgstr "Rochtain ar Gach Rogha Malartach"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:25
#, kde-format
msgctxt "@tooltip"
msgid "Access any possible substitutions."
msgstr "Rochtain a fháil ar aon ionaduithe féideartha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:29
#, kde-format
msgctxt "@title"
msgid "Contextual Alternates"
msgstr "Malartaigh Chomhthéacsúla"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:30
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs depending on their context within a text."
msgstr ""
"Cuireann sé glifí in ionad a chéile ag brath ar a gcomhthéacs laistigh de "
"théacs."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:33
#, kde-format
msgctxt "@title"
msgid "Contextual Ligatures"
msgstr "Ligatúir Chomhthéacsúla"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:34
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of glyphs with ligatures depending on their context "
"within a text."
msgstr ""
"Cuireann sé ligatúir in ionad seichimh glifí ag brath ar a gcomhthéacs "
"laistigh de théacs."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:37
#, kde-format
msgctxt "@title"
msgid "Contextual Swash"
msgstr "Swash Comhthéacsúil"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:38
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs with swashed glyphs depending on their context within a text."
msgstr ""
"Cuireann sé glifí in ionad glifí atá faoi scáth ag brath ar a gcomhthéacs "
"laistigh de théacs."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:41
#, kde-format
msgctxt "@title"
msgid "Discretionary Ligatures"
msgstr "Ligatúir Roghnacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:42
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of glyphs with ligatures intended for typographic effect."
msgstr ""
"Cuireann sé ligatúir in ionad seichimh glifí atá beartaithe le haghaidh "
"éifeacht chlóghrafaíochta."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:45
#, kde-format
msgctxt "@title"
msgid "Final Glyph on Line Alternates"
msgstr "Malartaigh Deiridh ar Líne"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:46
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their line-end forms."
msgstr "Cuireann sé a bhfoirmeacha deireadh líne in ionad glifí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:49
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:53
#, kde-format
msgctxt "@title"
msgid "Historical Forms"
msgstr "Foirmeacha Stairiúla"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:50
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their historical forms."
msgstr "Cuireann sé a bhfoirmeacha stairiúla in ionad glifí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:54
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences glyphs with ligatures that were in use in the past, but "
"rare today."
msgstr ""
"Cuireann sé ligatúir a bhí in úsáid san am atá thart, ach atá "
"neamhchoitianta inniu, in ionad glifí seicheamh."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:57
#, kde-format
msgctxt "@title"
msgid "Justification Alternates"
msgstr "Malartacha Réasúnaithe"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:58
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with their alternates meant for justification."
msgstr ""
"Cuireann sé glifí in ionad a malartacha atá beartaithe le haghaidh údarú."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:61
#, kde-format
msgctxt "@title"
msgid "Standard Ligatures"
msgstr "Ligatúir Chaighdeánacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:62
#, kde-format
msgctxt "@tooltip"
msgid "Replaces sequences glyphs with common ligatures."
msgstr "Cuireann sé ligáitúir choitianta in ionad glifí seicheamh."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:65
#, kde-format
msgctxt "@title"
msgid "Left Bounds"
msgstr "Teorainneacha Clé"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:66
#, kde-format
msgctxt "@tooltip"
msgid "This adjusts glyphs so there is no space at the left side."
msgstr "Coigeartaíonn sé seo glifí ionas nach mbeidh aon spás ar an taobh clé."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:69
#, kde-format
msgctxt "@title"
msgid "Localized Forms"
msgstr "Foirmeacha Logánaithe"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:70
#, kde-format
msgctxt "@tooltip"
msgid "This replaces glyphs with language specific versions."
msgstr "Cuireann sé seo leaganacha teanga-shonracha in ionad glifí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:73
#, kde-format
msgctxt "@title"
msgid "Optical Bounds"
msgstr "Teorainneacha Optúla"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:74
#, kde-format
msgctxt "@tooltip"
msgid ""
"Adjusts glyphs so they align by their optical bounds. Doesn't do anything in "
"Krita."
msgstr ""
"Coigeartaíonn sé glifí ionas go mbeidh siad ailínithe de réir a "
"dteorainneacha optúla. Ní dhéanann sé aon rud i Krita."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:77
#, kde-format
msgctxt "@title"
msgid "Ornaments"
msgstr "Ornáidí"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:78
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ornaments for decorative purposes."
msgstr "Cuireann sé ornáidí in ionad glifí chun críocha maisiúla."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:81
#, kde-format
msgctxt "@title"
msgid "Randomize"
msgstr "Randamaigh"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:82
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with random alternates."
msgstr "Cuireann sé glifí in ionad roghanna malartacha randamacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:85
#, kde-format
msgctxt "@title"
msgid "Right Bounds"
msgstr "Teorainneacha Deise"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:86
#, kde-format
msgctxt "@tooltip"
msgid "This adjusts glyphs so there is no space at the right side."
msgstr ""
"Coigeartaíonn sé seo glifí ionas nach mbeidh aon spás ar an taobh deas."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:89
#, kde-format
msgctxt "@title"
msgid "Stylistic Alternates"
msgstr "Malartaigh Stíle"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:90
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs with stylistic alternates that do not fit in other "
"categories."
msgstr ""
"Cuireann sé glifí in ionad le roghanna stíle nach n-oireann do chatagóirí "
"eile."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:93
#, kde-format
msgctxt "@title"
msgid "Swash"
msgstr "Swash"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:94
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with swashed alternates."
msgstr "Cuireann sé glifí in ionad malairtí atá swashed."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:99
#, kde-format
msgctxt "@title"
msgid "Glyph Composition/Decomposition"
msgstr "Comhdhéanamh/Dianscaoileadh Glifí"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:100
#, kde-format
msgctxt "@tooltip"
msgid ""
"This composes or decomposes graphemes so that the resulting glyphs can later "
"be recomposed. Commonly used to handle diacritics."
msgstr ""
"Déanann sé seo graiféimí a chumadh nó a dhíscaoileadh ionas gur féidir na "
"glifí a eascraíonn as a athchumadh níos déanaí. Úsáidtear go coitianta é "
"chun déileáil le diaicritics."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:103
#, kde-format
msgctxt "@title"
msgid "Kerning"
msgstr "Cníorú"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:104
#, kde-format
msgctxt "@tooltip"
msgid "This controls kerning on the font."
msgstr "Rialaíonn sé seo kerning ar an gcló."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:107
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:111
#, kde-format
msgctxt "@title"
msgid "Mark Positioning"
msgstr "Suíomh Marcála"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:108
#, kde-format
msgctxt "@tooltip"
msgid ""
"This controls the positioning of mark glyphs on base glyphs. Commonly used "
"for diacritics."
msgstr ""
"Rialaíonn sé seo suíomh na nglif marc ar na glifí bonn. Úsáidtear go "
"coitianta le haghaidh diaicriticí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:112
#, kde-format
msgctxt "@tooltip"
msgid ""
"This controls the positioning of mark glyphs onto other mark glyphs. "
"Commonly used for diacritics."
msgstr ""
"Rialaíonn sé seo suíomh glifí marc ar glifí marc eile. Úsáidtear go "
"coitianta le haghaidh diaicriticí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:115
#, kde-format
msgctxt "@title"
msgid "Required Contextual Alternates"
msgstr "Malartaigh Chomhthéacsúla Riachtanacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:116
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs contextually with alternates, required to make the font work."
msgstr ""
"Cuireann sé glifí in ionad a chéile de réir comhthéacs le roghanna "
"malartacha, atá riachtanach chun go n-oibreoidh an cló."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:119
#, kde-format
msgctxt "@title"
msgid "Required Ligatures"
msgstr "Ligatúir Riachtanacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:120
#, kde-format
msgctxt "@tooltip"
msgid "Replaces sequences of glyphs with required ligatures."
msgstr "Cuireann sé ligáitúir riachtanacha in ionad seichimh glifí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:123
#, kde-format
msgctxt "@title"
msgid "Required Variation Alternates"
msgstr "Malartaigh Éagsúla Riachtanacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:124
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs in a variable font with ones suited for the current "
"variation."
msgstr ""
"Cuireann sé glifí in ionad cló athraitheach le cinn atá oiriúnach don athrú "
"reatha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:127
#, kde-format
msgctxt "@title"
msgid "Optical size"
msgstr "Méid optúil"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:128
#, kde-format
msgctxt "@tooltip"
msgid ""
"Indicates how much the font is suitable for its current size. Does nothing "
"in Krita."
msgstr ""
"Léiríonn sé cé chomh hoiriúnach is atá an cló dá mhéid reatha. Ní dhéanann "
"sé tada i Krita."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:131
#, kde-format
msgctxt "@title"
msgid "Vertical Kerning"
msgstr "Kerning Ingearach"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:132
#, kde-format
msgctxt "@tooltip"
msgid "This controls vertical kerning on the font."
msgstr "Rialaíonn sé seo kerning ingearach ar an gcló."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:137
#, kde-format
msgctxt "@title"
msgid "Alternative Fractions"
msgstr "Codáin Mhalartacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:138
#, kde-format
msgctxt "@tooltip"
msgid "Replaces figures separated by a slash with a nut fraction form."
msgstr "Cuireann sé foirm chodáin cnó in ionad figiúirí atá scartha le slais."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:141
#, kde-format
msgctxt "@title"
msgid "Denominators"
msgstr "Ainmneoirí"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:142
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces figures with forms that are suited to represent the denominator in "
"a fraction."
msgstr ""
"Cuireann sé foirmeacha in ionad figiúirí atá oiriúnach chun an t-ainmneoir i "
"gcodán a léiriú."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:145
#, kde-format
msgctxt "@title"
msgid "Dotless Forms"
msgstr "Foirmeacha Gan Poncanna"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:146
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces dotted letters such as i and j with dotless forms, for use in "
"mathematical formula."
msgstr ""
"Cuireann sé litreacha poncaithe ar nós i agus j in ionad litreacha gan "
"poncanna, le húsáid i bhfoirmlí matamaiticiúla."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:149
#, kde-format
msgctxt "@title"
msgid "Flattened accent forms"
msgstr "Foirmeacha béime cothromaithe"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:150
#, kde-format
msgctxt "@tooltip"
msgid "Replaces accents on capital letters with flattened forms."
msgstr "Cuireann sé foirmeacha cothroma in ionad béimní ar litreacha móra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:153
#, kde-format
msgctxt "@title"
msgid "Fractions"
msgstr "Codáin"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:154
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces figures separated by a slash with a proper diagonal fraction form. "
"If a font has the numerator and denominator features, and the numbers are "
"separated by a 'fraction slash' (U+2044), then this will replace the figures "
"with numerators before the slash and denominators after the slash."
msgstr ""
"Cuireann sé seo foirm chodáin thrasnánach chuí in ionad figiúirí atá scartha "
"le slais. Má tá gnéithe uimhreoir agus ainmneoir i gcló, agus má tá na "
"huimhreacha scartha le 'slais chodáin' (U+2044), cuirfidh sé seo uimhreoirí "
"roimh an slais agus ainmneoirí i ndiaidh na slaise in ionad na bhfigiúirí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:157
#, kde-format
msgctxt "@title"
msgid "Lining Figures"
msgstr "Figiúirí Líneála"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:158
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces oldstyle figures with lining figures, which harmonize well with "
"uppercase letters."
msgstr ""
"Cuireann sé figiúirí líneála in ionad seanfhigiúirí, a oireann go maith do "
"litreacha móra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:161
#, kde-format
msgctxt "@title"
msgid "Mathematical Greek"
msgstr "Gréigis Mhatamaiticiúil"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:162
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces normal Greek script with glyphs intended for mathematical usage."
msgstr ""
"Cuireann sé glifí atá beartaithe le haghaidh úsáide matamaiticiúla in ionad "
"an ghnáthscript Ghréagaigh."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:165
#, kde-format
msgctxt "@title"
msgid "Alternate Annotation Forms"
msgstr "Foirmeacha Anótála Malartacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:166
#, kde-format
msgctxt "@tooltip"
msgid "Replaces figures and letters with notational forms, like encircled."
msgstr ""
"Cuireann sé foirmeacha nótaíochta in ionad figiúirí agus litreacha, amhail "
"ciorclaithe."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:169
#, kde-format
msgctxt "@title"
msgid "Numerators"
msgstr "Uimhreoirí"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:170
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces figures with forms that are suited to represent the numerator in a "
"fraction."
msgstr ""
"Cuireann sé foirmeacha in ionad figiúirí atá oiriúnach chun an uimhreoir i "
"gcodán a léiriú."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:173
#, kde-format
msgctxt "@title"
msgid "Oldstyle Figures"
msgstr "Figiúirí Sean-Stíl"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:174
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces lining figures with oldstyle figures, which harmonize well with "
"lowercase letters."
msgstr ""
"Cuireann sé figiúirí seanstíl in ionad figiúirí líneála, a oireann go maith "
"do litreacha beaga."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:177
#, kde-format
msgctxt "@title"
msgid "Ordinals"
msgstr "Ordinéil"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:178
#, kde-format
msgctxt "@tooltip"
msgid "Replaces letters that follow figures with their ordinal forms."
msgstr ""
"Cuireann sé a bhfoirmeacha ordalacha in ionad litreacha a thagann i ndiaidh "
"figiúirí."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:181
#, kde-format
msgctxt "@title"
msgid "Proportional Figures"
msgstr "Figiúirí Comhréireacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:182
#, kde-format
msgctxt "@tooltip"
msgid "Replaces tabular figures with proportional figures."
msgstr "Cuireann sé figiúirí comhréireacha in ionad figiúirí táblacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:185
#, kde-format
msgctxt "@title"
msgid "Scientific Inferiors"
msgstr "Íochtarach Eolaíochta"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:186
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces glyphs with forms that are suited for displaying the number in "
"chemical formulas."
msgstr ""
"Cuireann sé seo foirmeacha in ionad glifí atá oiriúnach chun an uimhir a "
"thaispeáint i bhfoirmlí ceimiceacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:189
#, kde-format
msgctxt "@title"
msgid "Math script style alternates"
msgstr "Malartaigh stíl scripte matamaitice"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:190
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ones more suited for super- and subscripts."
msgstr ""
"Cuireann sé glifí in ionad cinn atá níos oiriúnaí do shárscríbhinní agus "
"foscríbhinní."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:193
#, kde-format
msgctxt "@title"
msgid "Subscript"
msgstr "Fo-scríbhinn"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:194
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ones more suited for subscript."
msgstr "Cuireann sé glifí in ionad cinn atá níos oiriúnaí do fho-scríbhinn."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:197
#, kde-format
msgctxt "@title"
msgid "Superscript"
msgstr "Forscríbhinn"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:198
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with ones more suited for superscript."
msgstr "Cuireann sé glifí in ionad cinn atá níos oiriúnaí do fhorscríbhinn."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:201
#, kde-format
msgctxt "@title"
msgid "Tabular Figures"
msgstr "Figiúirí Táblacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:202
#, kde-format
msgctxt "@tooltip"
msgid "Replaces proportional figures with tabular figures."
msgstr "Cuireann figiúirí táblacha in ionad figiúirí comhréireacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:205
#, kde-format
msgctxt "@title"
msgid "Slashed Zero"
msgstr "Nialas Gearrtha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:206
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the number zero with one that has a slash in the middle, which can "
"help prevent confusion with similar glyphs like the letter 'O'."
msgstr ""
"Cuireann sé ceann a bhfuil slais sa lár in ionad na huimhreach nialas, rud a "
"chabhróidh le mearbhall a sheachaint le glifí comhchosúla cosúil leis an "
"litir 'O'."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:211
#, kde-format
msgctxt "@title"
msgid "Case-Sensitive Forms"
msgstr "Foirmeacha Íogair ó thaobh Cás de"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:212
#, kde-format
msgctxt "@tooltip"
msgid ""
"Adjusts glyphs to work better with text that consists of only capitals or "
"lining figures."
msgstr ""
"Coigeartaíonn sé glifí chun go n-oibreoidh siad níos fearr le téacs nach "
"bhfuil ann ach príomhlitreacha nó figiúirí líneála."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:215
#, kde-format
msgctxt "@title"
msgid "Capital Spacing"
msgstr "Spásáil Chaipitil"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:216
#, kde-format
msgctxt "@tooltip"
msgid "Adjusts inter-glyph spacing for all-capital text."
msgstr "Coigeartaíonn sé spásáil idir glifí le haghaidh téacs uile-chaipitil."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:219
#, kde-format
msgctxt "@title"
msgid "Petite Capitals From Capitals"
msgstr "Príomhchathracha Petite ó Chathracha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:220
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces uppercase letters with petite capital forms, which are closer to "
"the x-height of a font than small capital forms."
msgstr ""
"Cuireann sé litreacha móra in ionad litreacha móra le foirmeacha caipitlí "
"petite, atá níos gaire d’airde-x cló ná foirmeacha caipitlí beaga."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:223
#, kde-format
msgctxt "@title"
msgid "Small Capitals From Capitals"
msgstr "Príomhlitreacha Beaga ó Phríomhlitreacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:224
#, kde-format
msgctxt "@tooltip"
msgid "Replaces uppercase letters with small capital forms."
msgstr "Cuireann sé litreacha móra in ionad litreacha móra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:227
#, kde-format
msgctxt "@title"
msgid "Petite Capitals"
msgstr "Príomhchathracha Petite"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:228
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces lowercase letters with petite capital forms, which are closer to "
"the x-height of a font than small capital forms."
msgstr ""
"Cuireann sé litreacha beaga in ionad litreacha petite, atá níos gaire "
"d’airde-x cló ná litreacha beaga."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:231
#, kde-format
msgctxt "@title"
msgid "Small Capitals"
msgstr "Príomhchathracha Beaga"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:232
#, kde-format
msgctxt "@tooltip"
msgid "Replaces lowercase letters with small capital forms."
msgstr "Cuireann sé litreacha beaga in ionad litreacha móra."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:235
#, kde-format
msgctxt "@title"
msgid "Titling"
msgstr "Teidealú"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:236
#, kde-format
msgctxt "@tooltip"
msgid "Replaces glyphs with alternate forms suited for header text."
msgstr ""
"Cuireann sé foirmeacha malartacha in ionad glifí atá oiriúnach do théacs "
"ceanntásca."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:239
#, kde-format
msgctxt "@title"
msgid "Unicase"
msgstr "Unicase"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:240
#, kde-format
msgctxt "@tooltip"
msgid "Replaces both upper and lowercase glyphs with unicase glyphs."
msgstr "Cuireann sé glifí aonchás in ionad glifí uachtair agus íochtair araon."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:245
#, kde-format
msgctxt "@title"
msgid "Above-base Forms"
msgstr "Foirmeacha Os Cionn an Bhunaidh"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:246
#, kde-format
msgctxt "@tooltip"
msgid ""
"Controls substitution for above base forms in Khmer and other Indic scripts"
msgstr ""
"Rialaíonn sé ionadú le haghaidh foirmeacha os cionn an bhunleibhéil i "
"scripteanna Ciméiris agus scripteanna Indeacha eile"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:249
#, kde-format
msgctxt "@title"
msgid "Above-base Mark Positioning"
msgstr "Suíomh Marc Os Cionn an Bhoinn"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:250
#, kde-format
msgctxt "@tooltip"
msgid "Controls above-base mark positioning for Indic scripts."
msgstr "Rialaíonn sé suíomh marc os cionn an bhoinn do scripteanna Indiach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:253
#, kde-format
msgctxt "@title"
msgid "Above-base Substitutions"
msgstr "Ionadaithe Os Cionn an Bhoinn"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:254
#, kde-format
msgctxt "@tooltip"
msgid "Controls above-base mark ligatures for Indic scripts."
msgstr ""
"Rialaíonn sé ligatúir marc os cionn an bhoinn le haghaidh scripteanna "
"Indiach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:257
#, kde-format
msgctxt "@title"
msgid "Akhand"
msgstr "Akhand"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:258
#, kde-format
msgctxt "@tooltip"
msgid "Controls Akhand ligatures for Indic scripts."
msgstr "Rialaíonn sé ligáitúir Akhand do scripteanna Indiach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:261
#, kde-format
msgctxt "@title"
msgid "Below-base Forms"
msgstr "Foirmeacha Faoi Bhun"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:262
#, kde-format
msgctxt "@tooltip"
msgid "Controls substitution for below base forms in Indic scripts."
msgstr ""
"Rialaíonn sé ionadú le haghaidh foirmeacha faoi bhun an bhoinn i scripteanna "
"Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:265
#, kde-format
msgctxt "@title"
msgid "Below-base Mark Positioning"
msgstr "Suíomh Marc Faoi Bhun an Bhun"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:266
#, kde-format
msgctxt "@tooltip"
msgid "Controls below-base mark positioning for Indic scripts."
msgstr ""
"Rialaíonn sé suíomh marcanna faoi bhun an bhoinn do scripteanna Indiach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:269
#, kde-format
msgctxt "@title"
msgid "Below-base Substitutions"
msgstr "Ionadaithe faoi bhun an bhoinn"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:270
#, kde-format
msgctxt "@tooltip"
msgid "Controls below-base mark ligatures for Indic scripts."
msgstr ""
"Rialaíonn sé ligatúir marc faoi bhun an bhoinn le haghaidh scripteanna "
"Indiach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:273
#, kde-format
msgctxt "@title"
msgid "Conjunct Form After Ro"
msgstr "Foirm Chomhcheangailte Tar éis Ro"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:274
#, kde-format
msgctxt "@tooltip"
msgid "Controls glyphs following conjoined Ro in Khmer script."
msgstr "Rialaíonn sé glifí i ndiaidh Ro comhcheangailte i script Khmer."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:277
#, kde-format
msgctxt "@title"
msgid "Conjunct Forms"
msgstr "Foirmeacha Comhcheangailte"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:278
#, kde-format
msgctxt "@tooltip"
msgid "Controls conjunct forms in Indic scripts."
msgstr "Rialaíonn sé foirmeacha comhcheangailte i scripteanna Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:281
#, kde-format
msgctxt "@title"
msgid "Distances"
msgstr "Faid"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:282
#, kde-format
msgctxt "@tooltip"
msgid "Controls distances in Indic scripts, to avoid collisions."
msgstr "Rialaíonn sé achair i scripteanna Indic, chun imbhuailtí a sheachaint."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:285
#, kde-format
msgctxt "@title"
msgid "Half Forms"
msgstr "Leathfhoirmeacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:286
#, kde-format
msgctxt "@tooltip"
msgid "Replaces consonants in Indic scripts with their half forms."
msgstr "Cuireann sé a leathfhoirmeacha in ionad consain i scripteanna Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:289
#, kde-format
msgctxt "@title"
msgid "Halant Forms"
msgstr "Foirmeacha Halant"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:290
#, kde-format
msgctxt "@tooltip"
msgid "Replaces consonants in Indic scripts with their halant forms."
msgstr "Cuireann sé foirmeacha halant in ionad consain i scripteanna Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:293
#, kde-format
msgctxt "@title"
msgid "Nukta Forms"
msgstr "Foirmeacha Nukta"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:294
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces consonants combined with Nukta in Indic scripts with their Nukta "
"forms."
msgstr ""
"Cuireann sé a bhfoirmeacha Nukta in ionad consain atá curtha le chéile le "
"Nukta i scripteanna Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:297
#, kde-format
msgctxt "@title"
msgid "Pre-base Forms"
msgstr "Foirmeacha Réamhbhunaidh"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:298
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces the pre-base form of a consonant in Khmer script, when a 'Coeng Ra' "
"situation occurs."
msgstr ""
"Cuireann sé ionad fhoirm réamhbhun an chonsain i script Khmer, nuair a "
"tharlaíonn cás 'Coeng Ra'."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:301
#, kde-format
msgctxt "@title"
msgid "Pre-base Substitutions"
msgstr "Ionadaithe Réamh-Bhonn"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:302
#, kde-format
msgctxt "@tooltip"
msgid "Replaces consonants with their pre-base forms in Indic scripts."
msgstr ""
"Cuireann sé a bhfoirmeacha réamhbhunacha in ionad consain i scripteanna "
"Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:305
#, kde-format
msgctxt "@title"
msgid "Post-base Forms"
msgstr "Foirmeacha Iar-bhunaidh"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:306
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces consonants with their post-base forms in Gurmukhi, Malayalam, and "
"Khmer."
msgstr ""
"Cuireann sé a bhfoirmeacha iar-bhunacha in ionad consain i nGurmukhi, "
"Mailéalaimis, agus Khmer."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:309
#, kde-format
msgctxt "@title"
msgid "Post-base Substitutions"
msgstr "Ionadaithe Iar-Bhonn"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:310
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces base glyphs and post-base glyphs with a ligature in Indic scripts."
msgstr ""
"Cuireann sé ligatúr in ionad glifí bunúsacha agus glifí iar-bhunbhunaithe i "
"scripteanna Indeacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:313
#, kde-format
msgctxt "@title"
msgid "Rakar Forms"
msgstr "Foirmeacha Rakar"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:314
#, kde-format
msgctxt "@tooltip"
msgid "Replaces sequences of glyphs in Indic scripts with their Rakar forms."
msgstr ""
"Cuireann sé seo foirmeacha Rakar in ionad seichimh de ghlifí i scripteanna "
"Indeacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:317
#, kde-format
msgctxt "@title"
msgid "Reph Form"
msgstr "Foirm iarratais"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:318
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces Reph forms in Indic scripts with a consonant and Halant sequence."
msgstr ""
"Cuireann sé seicheamh consain agus Halant in ionad foirmeacha Reph i "
"scripteanna Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:321
#, kde-format
msgctxt "@title"
msgid "Vattu Variants"
msgstr "Malartacha Vattu"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:322
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces ligatures in Indic scripts with a base consonant and Vattu form."
msgstr ""
"Cuireann sé consan bonn agus foirm Vattu in ionad ligáitúir i scripteanna "
"Indic."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:327
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:343
#, kde-format
msgctxt "@title"
msgid "Contextual Half-width Spacing"
msgstr "Spásáil Leathleithid Chomhthéacsúil"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:328
#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:440
#, kde-format
msgctxt "@tooltip"
msgid ""
"Respaces full-width glyphs to be half-width depending on the context, common "
"examples include CJK full-width brackets and other punctuation marks."
msgstr ""
"Athraíonn sé glifí lánleithid go leathleithid ag brath ar an gcomhthéacs, i "
"measc na samplaí coitianta tá lúibíní lánleithid CJK agus comharthaí "
"poncaíochta eile."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:331
#, kde-format
msgctxt "@title"
msgid "Centered CJK Punctuation"
msgstr "Poncaíocht CJK Láraithe"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:332
#, kde-format
msgctxt "@tooltip"
msgid "Adjusts non-centered punctuation to be centered in CJK scripts."
msgstr ""
"Coigeartaíonn sé poncaíocht neamhlárnaithe le bheith lárnaithe i scripteanna "
"CJK."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:335
#, kde-format
msgctxt "@title"
msgid "Expert Forms"
msgstr "Foirmeacha Saineolaithe"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:336
#, kde-format
msgctxt "@tooltip"
msgid "Replaces standard forms in Japanese fonts with expert forms."
msgstr ""
"Cuireann sé foirmeacha saineolaithe in ionad foirmeacha caighdeánacha i "
"gclónna Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:339
#, kde-format
msgctxt "@title"
msgid "Full Widths"
msgstr "Leithead Iomlán"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:340
#, kde-format
msgctxt "@tooltip"
msgid "Replaces or respaces proportional glyphs with full-width glyphs."
msgstr ""
"Cuireann sé glifí lánleithid in ionad nó athspásálann sé glifí comhréireacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:344
#, kde-format
msgctxt "@tooltip"
msgid ""
"Respaces full-width glyphs to be half-width, common examples include CJK "
"full-width brackets and other punctuation marks."
msgstr ""
"Athraíonn sé glifí lánleithid go leathleithead, i measc na samplaí coitianta "
"tá lúibíní lánleithid CJK agus marcálacha poncaíochta eile."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:347
#, kde-format
msgctxt "@title"
msgid "Horizontal Kana Alternates"
msgstr "Malartaigh Kana Cothrománacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:348
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces standard kana in Japanese fonts with ones suited for horizontal "
"layout."
msgstr ""
"Cuireann sé clónna atá oiriúnach do leagan amach cothrománach in ionad kana "
"caighdeánach i gclónna Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:351
#, kde-format
msgctxt "@title"
msgid "Hangul"
msgstr "Hangal"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:352
#, kde-format
msgctxt "@tooltip"
msgid "Replaces hanja in Korean with the corresponding hangul. Deprecated."
msgstr ""
"Cuirtear an hangul comhfhreagrach in ionad hanja sa Chóiréis. As feidhm."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:355
#, kde-format
msgctxt "@title"
msgid "Hojo Kanji Forms"
msgstr "Foirmeacha Hojo Kanji"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:356
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces 'JIS X 0213:2004' form kanji in Japanese fonts with the Hojo ('JIS "
"X 0212-1990') forms."
msgstr ""
"Cuirtear na foirmeacha Hojo ('JIS X 0212-1990') in ionad kanji 'JIS X "
"0213:2004' i gclónna Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:359
#, kde-format
msgctxt "@title"
msgid "Half Widths"
msgstr "Leathleithid"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:360
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces or respaces proportional or full-width glyphs with half-width "
"glyphs."
msgstr ""
"Cuireann sé glifí leathleithid in ionad nó ag athspásáil glifí comhréireacha "
"nó lánleithid."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:363
#, kde-format
msgctxt "@title"
msgid "Italics"
msgstr "Iodálach"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:364
#, kde-format
msgctxt "@tooltip"
msgid "Replaces Latin glyphs in a CJK font with their italic forms."
msgstr ""
"Cuireann sé a bhfoirmeacha iodálacha in ionad glifí Laidine i gcló CJK."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:367
#, kde-format
msgctxt "@title"
msgid "JIS78 Forms"
msgstr "Foirmeacha JIS78"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:368
#, kde-format
msgctxt "@tooltip"
msgid "Replaces standard form kanji in Japanese fonts with the JIS78 forms."
msgstr ""
"Cuireann sé na foirmeacha JIS78 in ionad an kanji chaighdeánaigh i gclónna "
"Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:371
#, kde-format
msgctxt "@title"
msgid "JIS83 Forms"
msgstr "Foirmeacha JIS83"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:372
#, kde-format
msgctxt "@tooltip"
msgid "Replaces standard form kanji in Japanese fonts with the JIS83 forms."
msgstr ""
"Cuireann sé na foirmeacha JIS83 in ionad an kanji chaighdeánaigh i gclónna "
"Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:375
#, kde-format
msgctxt "@title"
msgid "JIS90 Forms"
msgstr "Foirmeacha JIS90"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:376
#, kde-format
msgctxt "@tooltip"
msgid "Replaces standard form kanji in Japanese fonts with the JIS90 forms."
msgstr ""
"Cuireann sé na foirmeacha JIS90 in ionad an kanji chaighdeánaigh i gclónna "
"Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:379
#, kde-format
msgctxt "@title"
msgid "JIS2004 Forms"
msgstr "Foirmeacha JIS2004"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:380
#, kde-format
msgctxt "@tooltip"
msgid "Replaces standard form kanji in Japanese fonts with the JIS2004 forms."
msgstr ""
"Cuireann sé foirmeacha JIS2004 in ionad an kanji chaighdeánaigh i gclónna "
"Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:383
#, kde-format
msgctxt "@title"
msgid "Leading Jamo Forms"
msgstr "Foirmeacha Ceannródaíocha Jamo"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:384
#, kde-format
msgctxt "@tooltip"
msgid ""
"Replaces sequences of leading class Hangul Jamo with a combined leading form."
msgstr ""
"Cuireann sé foirm chomhcheangailte tosaigh in ionad seichimh den rang "
"tosaigh Hangul Jamo."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:387
#, kde-format
msgctxt "@title"
msgid "NLC Kanji Forms"
msgstr "Foirmeacha Kanji NLC"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:388
#, kde-format
msgctxt "@tooltip"
msgid "Replaces standard form kanji in Japanese fonts with the NLC forms."
msgstr ""
"Cuireann sé na foirmeacha NLC in ionad an kanji chaighdeánaigh i gclónna "
"Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:391
#, kde-format
msgctxt "@title"
msgid "Proportional Alternate Widths"
msgstr "Leithead Malartacha Comhréireacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:392
#, kde-format
msgctxt "@tooltip"
msgid "Respaces full-width glyphs to fit in a proportional context."
msgstr ""
"Athspásálann sé glifí lánleithid chun go n-oirfidh siad i gcomhthéacs "
"comhréireach."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:395
#, kde-format
msgctxt "@title"
msgid "Proportional Kana"
msgstr "Kana Comhréireach"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:396
#, kde-format
msgctxt "@tooltip"
msgid "Replaces full-width kana in Japanese fonts with proportional kana."
msgstr ""
"Cuireann sé kana comhréireach in ionad kana lánleithid i gclónna Seapánacha."

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:399
#, kde-format
msgctxt "@title"
msgid "Proportional Widths"
msgstr "Leitheadanna Comhréireacha"

#: libs/flake/text/KoOpenTypeFeatureInfoFactory.cpp:400
#, kde-format
msgctxt "@tooltip"
msgid "Replaces uniform-width glyphs with proportional glyphs."
